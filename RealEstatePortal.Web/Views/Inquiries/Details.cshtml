@using RealEstatePortal.Domain.Enums
@model RealEstatePortal.Application.Inquiries.Queries.InquiryDto
@{
    ViewData["Title"] = "Inquiry";
}

<a asp-action="Index" class="btn btn-link px-0">← Back to inquiries</a>

<h1>Inquiry from @Model.Name</h1>

<dl class="row">
    <dt class="col-sm-2">Listing</dt>
    <dd class="col-sm-10">
        <a asp-controller="Listings" asp-action="Details" asp-route-id="@Model.ListingId">@Model.ListingTitle</a>
    </dd>
    <dt class="col-sm-2">Status</dt>
    <dd class="col-sm-10">@Model.Status</dd>
    <dt class="col-sm-2">Email</dt>
    <dd class="col-sm-10"><a href="mailto:@Model.Email">@Model.Email</a></dd>
    <dt class="col-sm-2">Phone</dt>
    <dd class="col-sm-10">@(string.IsNullOrWhiteSpace(Model.Phone) ? "—" : Model.Phone)</dd>
    <dt class="col-sm-2">Received</dt>
    <dd class="col-sm-10">@Model.Created.ToLocalTime().ToString("f")</dd>
</dl>

<h4>Message</h4>
<p style="white-space: pre-wrap;">@Model.Message</p>

@if (Model.Status != InquiryStatus.Handled)
{
    <form asp-action="MarkHandled" asp-route-id="@Model.Id" method="post">
        <button type="submit" class="btn btn-success">Mark as handled</button>
    </form>
}