@using RealEstatePortal.Domain.Enums
@model List<RealEstatePortal.Application.Inquiries.Queries.InquiryDto>
@{
    ViewData["Title"] = "Inquiries";
}

<div class="dash">
    <div class="container">
        <div class="dash-head">
            <div>
                <span class="eyebrow">Agent dashboard</span>
                <h1 class="page-title">Inquiries</h1>
            </div>
        </div>

        @if (!Model.Any())
        {
            <div class="form-card card-empty">No inquiries yet.</div>
        }
        else
        {
            <div class="table-card">
                <table class="table">
                    <thead>
                        <tr><th>Status</th><th>Listing</th><th>From</th><th>Received</th><th></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var inq in Model)
                        {
                            <tr class="@(inq.Status == InquiryStatus.New ? "unread-row" : "")">
                                <td>
                                    @switch (inq.Status)
                                    {
                                        case InquiryStatus.New:
                                            <span class="badge-status badge-sold">New</span>
                                            break;
                                        case InquiryStatus.Read:

                                            <span class="badge-status badge-draft">Read</span>
                                            break;
                                        case InquiryStatus.Handled:

                                            <span class="badge-status badge-active">Handled</span>
                                            break;
                                    }
                                </td>
                                <td class="row-title">@inq.ListingTitle</td>
                                <td>@inq.Name</td>
                                <td class="muted">@inq.Created.ToLocalTime().ToString("g")</td>
                                <td><div class="row-actions"><a asp-action="Details" asp-route-id="@inq.Id" class="btn btn-ghost btn-sm">View</a></div></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>