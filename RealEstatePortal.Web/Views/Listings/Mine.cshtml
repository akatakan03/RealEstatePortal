@using RealEstatePortal.Domain.Enums
@model List<RealEstatePortal.Application.Listings.Queries.GetListings.ListingBriefDto>
@{
    ViewData["Title"] = "My Listings";
}

<div class="dash">
    <div class="container">
        <div class="dash-head">
            <div>
                <span class="eyebrow">Agent dashboard</span>
                <h1 class="page-title">My listings</h1>
            </div>
            <a class="btn btn-primary" asp-action="Create">+ New listing</a>
        </div>

        @if (!Model.Any())
        {
            <div class="form-card" style="text-align:center;color:var(--muted);">
                You haven't created any listings yet. <a asp-action="Create" style="color:var(--brass-dk);font-weight:600;">Add your first one</a>.
            </div>
        }
        else
        {
            <div class="table-card">
                <table class="table">
                    <thead>
                        <tr><th>Title</th><th>Type</th><th>Price</th><th>Status</th><th></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var l in Model)
                        {
                            <tr>
                                <td class="row-title">@l.Title</td>
                                <td>@l.ListingType</td>
                                <td><span class="value">@l.PriceAmount.ToString("N0") @l.PriceCurrency</span></td>
                                <td>
                                    <span class="badge-status badge-@l.Status.ToString().ToLower()">@l.Status</span>
                                </td>
                                <td>
                                    @if (l.IsLocked)
                                    {
                                        <span class="badge-status badge-archived">🔒 Locked</span>
                                    }
                                    else
                                    {
                                        <span class="badge-status badge-@l.Status.ToString().ToLower()">@l.Status</span>
                                    }
                                </td>
                                <td>
                                    @if (l.IsLocked)
                                    {
                                        <div class="locked-msg">
                                            <strong>Locked by an administrator.</strong>
                                            <span>@l.LockReason</span>
                                            <small>Contact support once resolved.</small>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="row-actions">
                                            @if (l.Status == ListingStatus.Draft)
                                            {
                                                <form asp-action="Publish" asp-route-id="@l.Id" method="post">
                                                    <button type="submit" class="btn btn-primary btn-sm">Publish</button>
                                                </form>
                                            }
                                            <a asp-action="Edit" asp-route-id="@l.Id" class="btn btn-ghost btn-sm">Edit</a>
                                            <a asp-action="Delete" asp-route-id="@l.Id" class="btn btn-danger btn-sm">Delete</a>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>