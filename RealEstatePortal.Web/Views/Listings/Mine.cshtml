@using RealEstatePortal.Domain.Enums
@model List<RealEstatePortal.Application.Listings.Queries.GetMyListings.MyListingDto>
@{
    ViewData["Title"] = "My Listings";
}

<div class="dash">
    <div class="container">
        <div class="dash-head">
            <div>
                <span class="eyebrow">Agent dashboard</span>
                <h1 class="page-title">My listings</h1>
            </div>
            <a class="btn btn-primary" asp-action="Create">+ New listing</a>
        </div>

        @if (TempData["UnlockRequested"] is string sent)
        {
            <div class="alert alert-success" style="margin-bottom:1.5rem;">@sent</div>
        }

        @if (!Model.Any())
        {
            <div class="form-card" style="text-align:center;color:var(--muted);">
                You haven't created any listings yet. <a asp-action="Create" style="color:var(--brass-dk);font-weight:600;">Add your first one</a>.
            </div>
        }
        else
        {
            <div class="listing-toolbar">
                <div class="filter-tabs" role="tablist">
                    <button type="button" class="filter-tab is-active" data-filter="all">All <span class="ft-count">@Model.Count</span></button>
                    <button type="button" class="filter-tab" data-filter="active">Active <span class="ft-count">@Model.Count(l => !l.IsLocked && l.Status == ListingStatus.Active)</span></button>
                    <button type="button" class="filter-tab" data-filter="draft">Draft <span class="ft-count">@Model.Count(l => !l.IsLocked && l.Status == ListingStatus.Draft)</span></button>
                    <button type="button" class="filter-tab" data-filter="archived">Archived <span class="ft-count">@Model.Count(l => !l.IsLocked && l.Status == ListingStatus.Archived)</span></button>
                    <button type="button" class="filter-tab" data-filter="locked">Locked <span class="ft-count">@Model.Count(l => l.IsLocked)</span></button>
                </div>
                <input type="search" id="listingSearch" class="listing-search" placeholder="Search by title…" autocomplete="off" />
            </div>

            <div class="table-card">
                <table class="table" id="myListingsTable">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Type</th>
                            <th>Price</th>
                            <th>Status</th>
                            <th class="num">Views</th>
                            <th class="num">Inquiries</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var l in Model)
                        {
                            var rowStatus = l.IsLocked ? "locked" : l.Status.ToString().ToLower();
                            <tr data-status="@rowStatus" data-title="@l.Title.ToLowerInvariant()">
                                <td class="row-title">
                                    <div class="listing-cell">
                                        @if (!string.IsNullOrEmpty(l.CoverThumbnailUrl))
                                        {
                                            <img class="listing-thumb" src="@l.CoverThumbnailUrl" alt="" loading="lazy" />
                                        }
                                        else
                                        {
                                            <span class="listing-thumb listing-thumb-empty" aria-hidden="true">⌂</span>
                                        }
                                        <span class="listing-cell-title">@l.Title</span>
                                    </div>
                                </td>
                                <td>@l.ListingType</td>
                                <td><span class="value">@l.PriceAmount.ToString("N0") @l.PriceCurrency</span></td>
                                <td>
                                    @if (l.IsLocked)
                                    {
                                        <span class="badge-status badge-archived">🔒 Locked</span>
                                    }
                                    else
                                    {
                                        <span class="badge-status badge-@l.Status.ToString().ToLower()">@l.Status</span>
                                    }
                                </td>
                                <td class="num">@l.Views.ToString("N0")</td>
                                <td class="num">@l.Inquiries.ToString("N0")</td>
                                <td>
                                    @if (l.IsLocked)
                                    {
                                        <div class="locked-msg">
                                            <strong>Locked by an administrator.</strong>
                                            <span>@l.LockReason</span>
                                            @if (l.UnlockRequested)
                                            {
                                                <small class="review-requested">⏳ Re-review requested@(l.UnlockRequestedAt is null ? "" : $" on {l.UnlockRequestedAt:MMM d, yyyy}"). An admin will take another look.</small>
                                            }
                                            else
                                            {
                                                <details class="unlock-appeal">
                                                    <summary>Fixed it — request re-review</summary>
                                                    <form asp-action="RequestUnlock" asp-route-id="@l.Id" method="post">
                                                        <textarea name="note" maxlength="1000" rows="3" placeholder="Optional: tell the admin what you changed (e.g. replaced the photos)."></textarea>
                                                        <button type="submit" class="btn btn-primary btn-sm">Send request</button>
                                                    </form>
                                                </details>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="row-actions">
                                            @if (l.Status == ListingStatus.Draft)
                                            {
                                                <form asp-action="Publish" asp-route-id="@l.Id" method="post">
                                                    <button type="submit" class="btn btn-primary btn-sm">Publish</button>
                                                </form>
                                            }
                                            <a asp-action="Details" asp-route-id="@l.Id" asp-route-slug="@l.Slug" class="btn btn-ghost btn-sm" target="_blank" rel="noopener">@(l.Status == ListingStatus.Active ? "View" : "Preview")</a>
                                            <a asp-action="Edit" asp-route-id="@l.Id" class="btn btn-ghost btn-sm">Edit</a>
                                            <a asp-action="Delete" asp-route-id="@l.Id" class="btn btn-danger btn-sm">Delete</a>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <p id="noListingMatch" class="no-match" hidden>No listings match your filters.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="~/js/my-listings.js" asp-append-version="true"></script>
}
