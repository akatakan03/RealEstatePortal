@using RealEstatePortal.Domain.Enums
@model RealEstatePortal.Web.Models.Listings.ListingBrowseViewModel
@{
    ViewData["Title"] = "Browse Listings";
    var routeData = Model.CurrentFilter();
    var hasCenter = Model.Filter.CenterLat.HasValue && Model.Filter.CenterLng.HasValue;
    var currentRadius = Model.Filter.RadiusKm ?? 10;

    var mapPoints = Model.Listings.Items
        .Where(i => i.Latitude.HasValue && i.Longitude.HasValue)
        .Select(i => new
        {
            id = i.Id,
            slug = i.Slug,
            lat = i.Latitude!.Value,
            lng = i.Longitude!.Value,
            title = i.Title,
            price = i.PriceAmount.ToString("N0") + " " + i.PriceCurrency
        });
    var mapPointsJson = System.Text.Json.JsonSerializer.Serialize(mapPoints);
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<section class="browse-hero">
    <div class="container">
        <span class="eyebrow">İstanbul property, curated</span>
        <h1>Find the place that <em>feels</em> like yours.</h1>
        <p class="lead">Verified listings from local agents — filter by area, type, and price to find your next home.</p>

        <div class="console-wrap rise d1">
            <form asp-action="Index" method="get" class="console">
                <div class="field">
                    <label>Location</label>
                    <input name="Keyword" value="@Model.Filter.Keyword" placeholder="Neighbourhood or address" />
                </div>
                <div class="field">
                    <label>Type</label>
                    <select name="ListingType">
                        <option value="">Any type</option>
                        @foreach (var t in Enum.GetValues<ListingType>())
                        {
                            <option value="@t" selected="@(Model.Filter.ListingType == t)">@t</option>
                        }
                    </select>
                </div>
                <div class="field">
                    <label>Property</label>
                    <select name="PropertyType">
                        <option value="">Any property</option>
                        @foreach (var p in Enum.GetValues<PropertyType>())
                        {
                            <option value="@p" selected="@(Model.Filter.PropertyType == p)">@p</option>
                        }
                    </select>
                </div>
                <div class="field">
                    <label>Max price</label>
                    <input name="MaxPrice" value="@Model.Filter.MaxPrice" placeholder="Any" />
                </div>
                <div class="search-cell">
                    <button type="submit" class="btn btn-primary">Search</button>
                </div>

                @if (hasCenter)
                {
                    <input type="hidden" name="CenterLat" value="@Model.Filter.CenterLat" />
                    <input type="hidden" name="CenterLng" value="@Model.Filter.CenterLng" />
                    <input type="hidden" name="RadiusKm" value="@Model.Filter.RadiusKm" />
                }
            </form>
        </div>
    </div>
</section>

<section class="listings-sec">
    <div class="container">
        <div class="map-bar">
            <label>Search on the map:</label>
            <select id="radiusSelect" class="form-select select-inline">
                @foreach (var km in new[] { 1, 5, 10, 25, 50 })
                {
                    <option value="@km" selected="@(currentRadius == km)">@km km</option>
                }
            </select>
            <button type="button" id="searchAreaBtn" class="btn btn-ghost btn-sm">Search this area</button>
            @if (hasCenter)
            {
                <a class="btn btn-ghost btn-sm" asp-action="Index" asp-all-route-data="routeData">Clear area</a>
                <span class="note">Within @currentRadius km of the marked area.</span>
            }
            else
            {
                <span class="note">Pan the map, then search its current area.</span>
            }
        </div>

        <div id="browseMap"></div>

        <div class="sec-head">
            <h2>Homes on the market</h2>
            <span class="count">@Model.Listings.TotalCount listing@(Model.Listings.TotalCount == 1 ? "" : "s")</span>
        </div>

        @if (!Model.Listings.Items.Any())
        {
            <div class="empty-state">
                <span class="value">No matches</span>
                Try widening your filters or clearing the map area.
            </div>
        }
        else
        {
            <div class="card-grid">
                @foreach (var listing in Model.Listings.Items)
                {
                    <a class="listing-card rise d1" asp-action="Details" asp-route-id="@listing.Id" asp-route-slug="@listing.Slug">
                        <div class="lc-media">
                            @if (User.Identity is not null && User.Identity.IsAuthenticated)
                            {
                                <button type="button"
                                        class="lc-fav @(listing.IsFavorited ? "is-fav" : "")"
                                        data-listing-id="@listing.Id"
                                        aria-label="Save listing"
                                        onclick="toggleFav(event, this)">
                                    @(listing.IsFavorited ? "♥" : "♡")
                                </button>
                            }
                            <span class="lc-tag @(listing.ListingType == ListingType.Rent ? "rent" : "")">@listing.ListingType</span>
                            @if (!string.IsNullOrEmpty(listing.CoverThumbnailUrl))
                            {
                                <img src="@listing.CoverThumbnailUrl" alt="@listing.Title" />
                            }
                            else
                            {
                                <div class="noimg">No photo yet</div>
                            }
                        </div>
                        <div class="lc-body">
                            <div class="lc-loc">@listing.PropertyType</div>
                            <div class="lc-title">@listing.Title</div>
                            <div class="lc-meta">
                                <span><span class="value">@listing.Bedrooms</span> bd</span>
                                <span><span class="value">@listing.AreaSqMeters.ToString("N0")</span> m²</span>
                            </div>
                            <div class="lc-price">
                                <span class="value">@listing.PriceAmount.ToString("N0") @listing.PriceCurrency</span>
                            </div>
                        </div>
                    </a>
                }
            </div>

            <nav class="pager">
                @if (Model.Listings.HasPreviousPage)
                {
                    <a asp-action="Index" asp-all-route-data="routeData" asp-route-pageNumber="@(Model.Listings.PageNumber - 1)">← Prev</a>
                }
                else
                {
                    <span class="disabled">← Prev</span>
                }
                <span class="current">@Model.Listings.PageNumber of @Model.Listings.TotalPages</span>
                @if (Model.Listings.HasNextPage)
                {
                    <a asp-action="Index" asp-all-route-data="routeData" asp-route-pageNumber="@(Model.Listings.PageNumber + 1)">Next →</a>
                }
                else
                {
                    <span class="disabled">Next →</span>
                }
            </nav>
        }
    </div>
    <form id="favToken" style="display:none;">@Html.AntiForgeryToken()</form>
</section>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        (function () {
        var listingsData = @Html.Raw(mapPointsJson);
        var hasCenter = @(hasCenter ? "true" : "false");
        @if (hasCenter)
        {
            <text>
                var searchCenter = {
                lat: @Model.Filter.CenterLat!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture),
                lng: @Model.Filter.CenterLng!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)
                };
                var searchRadiusKm = @currentRadius;
            </text>
        }

        function esc(s){var d=document.createElement('div');d.textContent=s==null?'':s;return d.innerHTML;}

        var map = L.map('browseMap');
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19, attribution: '© OpenStreetMap contributors'
        }).addTo(map);

        var markers = [];
        listingsData.forEach(function (p) {
        var m = L.marker([p.lat, p.lng]).addTo(map);
        m.bindPopup('<strong>' + esc(p.title) + '</strong><br/>' + esc(p.price) +
        '<br/><a href="/listing/' + p.id + '/' + p.slug + '">View details</a>');
        markers.push(m);
        });

        if (hasCenter) {
        map.setView([searchCenter.lat, searchCenter.lng], 12);
        L.circle([searchCenter.lat, searchCenter.lng], {
        radius: searchRadiusKm * 1000, color:'#B08A4F', weight:1, fillColor:'#B08A4F', fillOpacity:.06
        }).addTo(map);
        } else if (markers.length > 0) {
        map.fitBounds(L.featureGroup(markers).getBounds().pad(0.2));
        } else {
        map.setView([39.0, 35.0], 6);
        }

        document.getElementById('searchAreaBtn').addEventListener('click', function () {
        var c = map.getCenter();
        var radius = document.getElementById('radiusSelect').value;
        var params = new URLSearchParams(window.location.search);
        params.set('CenterLat', c.lat.toFixed(6));
        params.set('CenterLng', c.lng.toFixed(6));
        params.set('RadiusKm', radius);
        params.set('pageNumber', '1');
        window.location = window.location.pathname + '?' + params.toString();
        });
        })();

        function toggleFav(event, btn) {
        event.preventDefault();
        event.stopPropagation();   // don't trigger the card's link
        var id = btn.getAttribute('data-listing-id');
        var token = document.querySelector('#favToken input[name="__RequestVerificationToken"]').value;

        fetch('/Favorites/ToggleAjax', {
        method: 'POST',
        headers: { 'RequestVerificationToken': token, 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'listingId=' + encodeURIComponent(id)
        })
        .then(function (r) { return r.json(); })
        .then(function (d) {
        if (d.favorited) { btn.classList.add('is-fav'); btn.textContent = '♥'; }
        else { btn.classList.remove('is-fav'); btn.textContent = '♡'; }
        })
        .catch(function () { /* leave the heart unchanged on failure */ });
        }
    </script>


}