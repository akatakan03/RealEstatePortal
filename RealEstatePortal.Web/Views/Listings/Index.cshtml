@using RealEstatePortal.Domain.Enums
@using RealEstatePortal.Application.Listings.Queries.GetPublicListings
@model RealEstatePortal.Web.Models.Listings.ListingBrowseViewModel
@{
    ViewData["Title"] = "Browse Listings";
    var routeData = Model.CurrentFilter();
    var hasCenter = Model.Filter.CenterLat.HasValue && Model.Filter.CenterLng.HasValue;
    var currentRadius = Model.Filter.RadiusKm ?? 10;

    // Gelişmiş filtrelerden herhangi biri aktifse panelin açık kalmasını sağlayan yardımcı metot
    bool HasAdvancedFilter(GetPublicListingsQuery f) =>
        f.Heating.HasValue || f.Internet.HasValue || f.Furnished == true ||
        f.Parking == true || f.Balcony == true || f.MaxDues.HasValue || f.MinBedrooms.HasValue;
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css" />

<section class="browse-hero">
    <div class="container">
        <span class="eyebrow">İstanbul property, curated</span>
        <h1>Find the place that <em>feels</em> like yours.</h1>
        <p class="lead">Verified listings from local agents — filter by area, type, and price to find your next home.</p>

        <div class="console-wrap rise d1">
            <form asp-action="Index" method="get">
                <div class="console">
                    <div class="field">
                        <label>Location</label>
                        <input name="Keyword" value="@Model.Filter.Keyword" placeholder="Neighbourhood or address" />
                    </div>
                    <div class="field">
                        <label>Type</label>
                        <select name="ListingType">
                            <option value="">Any type</option>
                            @foreach (var t in Enum.GetValues<ListingType>())
                            {
                                <option value="@t" selected="@(Model.Filter.ListingType == t)">@t</option>
                            }
                        </select>
                    </div>
                    <div class="field">
                        <label>Property</label>
                        <select name="PropertyType">
                            <option value="">Any property</option>
                            @foreach (var p in Enum.GetValues<PropertyType>())
                            {
                                <option value="@p" selected="@(Model.Filter.PropertyType == p)">@p</option>
                            }
                        </select>
                    </div>
                    <div class="field">
                        <label>Max price</label>
                        <input name="MaxPrice" value="@Model.Filter.MaxPrice" placeholder="Any" />
                    </div>
                    <div class="search-cell">
                        <button type="submit" class="btn btn-primary">Search</button>
                    </div>
                </div>

                @* Gelişmiş Filtreler Paneli *@
                <details class="more-filters" @(HasAdvancedFilter(Model.Filter) ? "open" : "")>
                    <summary>More filters</summary>
                    <div class="filter-grid">
                        <div class="mb-field">
                            <label class="form-label">Heating</label>
                            <select name="Heating" class="form-select">
                                <option value="">Any</option>
                                @foreach (var h in Enum.GetValues<RealEstatePortal.Domain.Enums.HeatingType>())
                                {
                                    <option value="@h" selected="@(Model.Filter.Heating == h)">@h</option>
                                }
                            </select>
                        </div>
                        <div class="mb-field">
                            <label class="form-label">Internet</label>
                            <select name="Internet" class="form-select">
                                <option value="">Any</option>
                                @foreach (var i in Enum.GetValues<RealEstatePortal.Domain.Enums.InternetInfrastructure>())
                                {
                                    <option value="@i" selected="@(Model.Filter.Internet == i)">@i</option>
                                }
                            </select>
                        </div>
                        <div class="mb-field">
                            <label class="form-label">Min bedrooms</label>
                            <input name="MinBedrooms" value="@Model.Filter.MinBedrooms" class="form-control" placeholder="Any" />
                        </div>
                        <div class="mb-field">
                            <label class="form-label">Max monthly dues</label>
                            <input name="MaxDues" value="@Model.Filter.MaxDues" class="form-control" placeholder="Any" />
                        </div>
                    </div>
                    <div class="filter-checks">
                        <label><input type="checkbox" name="Furnished" value="true" @(Model.Filter.Furnished == true ? "checked" : "") /> Furnished</label>
                        <label><input type="checkbox" name="Parking" value="true" @(Model.Filter.Parking == true ? "checked" : "") /> Parking</label>
                        <label><input type="checkbox" name="Balcony" value="true" @(Model.Filter.Balcony == true ? "checked" : "") /> Balcony</label>
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm" style="margin-top:1rem;">Apply filters</button>
                </details>

                @if (hasCenter)
                {
                    <input type="hidden" name="CenterLat" value="@Model.Filter.CenterLat" />
                    <input type="hidden" name="CenterLng" value="@Model.Filter.CenterLng" />
                    <input type="hidden" name="RadiusKm" value="@Model.Filter.RadiusKm" />
                }
            </form>
        </div>
    </div>
</section>

<section class="listings-sec">
    <div class="container">
        <div class="map-bar">
            @if (User.Identity is not null && User.Identity.IsAuthenticated)
            {
                <form asp-controller="SavedSearches" asp-action="Create" method="post"
                      style="display:flex;gap:.6rem;align-items:center;margin-bottom:1.5rem;flex-wrap:wrap;">
                    <input type="hidden" name="Keyword" value="@Model.Filter.Keyword" />
                    <input type="hidden" name="ListingType" value="@Model.Filter.ListingType" />
                    <input type="hidden" name="PropertyType" value="@Model.Filter.PropertyType" />
                    <input type="hidden" name="MaxPrice" value="@Model.Filter.MaxPrice" />
                    <input type="hidden" name="MinBedrooms" value="@Model.Filter.MinBedrooms" />
                    <input name="Name" class="form-control" style="max-width:260px;" placeholder="Name this search (e.g. Kadıköy flats)" />
                    <button type="submit" class="btn btn-ghost btn-sm">🔔 Save this search</button>
                </form>
            }
            <label>Search on the map:</label>
            <select id="radiusSelect" class="form-select select-inline">
                @foreach (var km in new[] { 1, 5, 10, 25, 50 })
                {
                    <option value="@km" selected="@(currentRadius == km)">@km km</option>
                }
            </select>
            <button type="button" id="searchAreaBtn" class="btn btn-ghost btn-sm">Search this area</button>
            @if (hasCenter)
            {
                <a class="btn btn-ghost btn-sm" asp-action="Index" asp-all-route-data="routeData">Clear area</a>
                <span class="note">Within @currentRadius km of the marked area.</span>
            }
            else
            {
                <span class="note">Pan the map, then search its current area.</span>
            }
        </div>

        <div id="browseMap"></div>

        <div class="sec-head">
            <h2>Homes on the market</h2>
            <div class="sec-head-right">
                <select id="sortSelect" class="form-select select-inline" onchange="applySort(this.value)" aria-label="Sort listings">
                    <option value="Newest" selected="@(Model.Filter.Sort == ListingSort.Newest)">Newest</option>
                    <option value="PriceAsc" selected="@(Model.Filter.Sort == ListingSort.PriceAsc)">Price: low to high</option>
                    <option value="PriceDesc" selected="@(Model.Filter.Sort == ListingSort.PriceDesc)">Price: high to low</option>
                    <option value="AreaDesc" selected="@(Model.Filter.Sort == ListingSort.AreaDesc)">Area: largest first</option>
                </select>
                <span class="count">@Model.Listings.TotalCount listing@(Model.Listings.TotalCount == 1 ? "" : "s")</span>
            </div>
        </div>

        @if (!Model.Listings.Items.Any())
        {
            <div class="empty-state">
                <span class="value">No matches</span>
                Try widening your filters or clearing the map area.
            </div>
        }
        else
        {
            <div class="card-grid">
                @foreach (var listing in Model.Listings.Items)
                {
                    <a class="listing-card rise d1" asp-action="Details" asp-route-id="@listing.Id" asp-route-slug="@listing.Slug">
                        <div class="lc-media">
                            @if (User.Identity is not null && User.Identity.IsAuthenticated)
                            {
                                <button type="button"
                                        class="lc-fav @(listing.IsFavorited ? "is-fav" : "")"
                                        data-listing-id="@listing.Id"
                                        aria-label="Save listing"
                                        onclick="toggleFav(event, this)">
                                    @(listing.IsFavorited ? "♥" : "♡")
                                </button>
                            }
                            <span class="lc-tag @(listing.ListingType == ListingType.Rent ? "rent" : "")">@listing.ListingType</span>
                            @{ var cover = ListingImages.CoverOrPlaceholder(listing.CoverThumbnailUrl, listing.Id, Configuration.GetValue<bool>("Demo:PlaceholderImages")); }
                            @if (!string.IsNullOrEmpty(cover))
                            {
                                <img src="@cover" alt="@listing.Title" loading="lazy" />
                            }
                            else
                            {
                                <div class="noimg">No photo yet</div>
                            }
                        </div>
                        <div class="lc-body">
                            <div class="lc-loc">@listing.PropertyType</div>
                            <div class="lc-title">@listing.Title</div>
                            <div class="lc-meta">
                                <span><span class="value">@listing.Bedrooms</span> bd</span>
                                <span><span class="value">@listing.AreaSqMeters.ToString("N0")</span> m²</span>
                            </div>
                            <div class="lc-price">
                                <span class="value">@listing.PriceAmount.ToString("N0") @listing.PriceCurrency</span>
                            </div>
                        </div>
                    </a>
                }
            </div>

            <nav class="pager">
                @if (Model.Listings.HasPreviousPage)
                {
                    <a asp-action="Index" asp-all-route-data="routeData" asp-route-pageNumber="@(Model.Listings.PageNumber - 1)">← Prev</a>
                }
                else
                {
                    <span class="disabled">← Prev</span>
                }
                <span class="current">@Model.Listings.PageNumber of @Model.Listings.TotalPages</span>
                @if (Model.Listings.HasNextPage)
                {
                    <a asp-action="Index" asp-all-route-data="routeData" asp-route-pageNumber="@(Model.Listings.PageNumber + 1)">Next →</a>
                }
                else
                {
                    <span class="disabled">Next →</span>
                }
            </nav>
        }
    </div>
    <form id="favToken" style="display:none;">@Html.AntiForgeryToken()</form>
</section>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js"></script>
    <script>
        (function () {
        var hasCenter = @(hasCenter ? "true" : "false");
        @if (hasCenter)
        {
            <text>
                var searchCenter = {
                lat: @Model.Filter.CenterLat!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture),
                lng: @Model.Filter.CenterLng!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)
                };
                var searchRadiusKm = @currentRadius;
            </text>
        }

        function esc(s){var d=document.createElement('div');d.textContent=s==null?'':s;return d.innerHTML;}

        var map = L.map('browseMap');
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19, attribution: '© OpenStreetMap contributors'
        }).addTo(map);

        // Cluster group keeps rendering cheap even with thousands of pins in view.
        var cluster = L.markerClusterGroup({ chunkedLoading: true });
        map.addLayer(cluster);

        if (hasCenter) {
        map.setView([searchCenter.lat, searchCenter.lng], 12);
        L.circle([searchCenter.lat, searchCenter.lng], {
        radius: searchRadiusKm * 1000, color:'#B08A4F', weight:1, fillColor:'#B08A4F', fillOpacity:.06
        }).addTo(map);
        } else {
        // Default to İstanbul; pins for whatever area the user pans to load on demand.
        map.setView([41.01, 28.97], 11);
        }

        // Carry the active list filters (keyword, type, price, …) into the pin request,
        // minus paging/area params the map manages itself.
        function baseFilterParams() {
        var params = new URLSearchParams(window.location.search);
        ['pageNumber', 'PageNumber', 'MinLat', 'MaxLat', 'MinLng', 'MaxLng'].forEach(function (k) {
        params.delete(k);
        });
        return params;
        }

        var reqToken = 0;
        function loadPins() {
        var b = map.getBounds();
        var params = baseFilterParams();
        params.set('MinLat', b.getSouth().toFixed(6));
        params.set('MaxLat', b.getNorth().toFixed(6));
        params.set('MinLng', b.getWest().toFixed(6));
        params.set('MaxLng', b.getEast().toFixed(6));

        var mine = ++reqToken;
        fetch('/Listings/MapPoints?' + params.toString())
        .then(function (r) { return r.json(); })
        .then(function (data) {
        if (mine !== reqToken) return; // a newer request already superseded this one
        cluster.clearLayers();
        var markers = data.map(function (p) {
        var m = L.marker([p.latitude, p.longitude]);
        m.bindPopup('<strong>' + esc(p.title) + '</strong><br/>' +
        esc(p.priceAmount.toLocaleString() + ' ' + p.priceCurrency) +
        '<br/><a href="/listing/' + p.id + '/' + p.slug + '">View details</a>');
        return m;
        });
        cluster.addLayers(markers);
        })
        .catch(function () { /* leave existing pins on failure */ });
        }

        // Debounce so panning/zooming doesn't fire a request on every frame.
        var debounceTimer;
        map.on('moveend', function () {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(loadPins, 250);
        });
        loadPins();

        document.getElementById('searchAreaBtn').addEventListener('click', function () {
        var c = map.getCenter();
        var radius = document.getElementById('radiusSelect').value;
        var params = new URLSearchParams(window.location.search);
        params.set('CenterLat', c.lat.toFixed(6));
        params.set('CenterLng', c.lng.toFixed(6));
        params.set('RadiusKm', radius);
        params.set('pageNumber', '1');
        window.location = window.location.pathname + '?' + params.toString();
        });
        })();

        // Re-run the search with a new sort, keeping all current filters, from page 1.
        function applySort(value) {
        var params = new URLSearchParams(window.location.search);
        params.set('Sort', value);
        params.set('pageNumber', '1');
        window.location = window.location.pathname + '?' + params.toString();
        }

        function toggleFav(event, btn) {
        event.preventDefault();
        event.stopPropagation();
        // don't trigger the card's link
        var id = btn.getAttribute('data-listing-id');
        var token = document.querySelector('#favToken input[name="__RequestVerificationToken"]').value;

        fetch('/Favorites/ToggleAjax', {
        method: 'POST',
        headers: { 'RequestVerificationToken': token, 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'listingId=' + encodeURIComponent(id)
        })
        .then(function (r) { return r.json(); })
        .then(function (d) {
        if (d.favorited) { btn.classList.add('is-fav'); btn.textContent = '♥'; }
        else { btn.classList.remove('is-fav'); btn.textContent = '♡'; }
        })
        .catch(function () { /* leave the heart unchanged on failure */ });
        }
    </script>
}