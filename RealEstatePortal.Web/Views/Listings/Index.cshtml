@using RealEstatePortal.Domain.Enums
@using RealEstatePortal.Application.Listings.Queries.GetPublicListings
@model RealEstatePortal.Web.Models.Listings.ListingBrowseViewModel
@{
    ViewData["Title"] = L["Browse listings"].Value;
    var routeData = Model.CurrentFilter();
    var hasCenter = Model.Filter.CenterLat.HasValue && Model.Filter.CenterLng.HasValue;
    var currentRadius = Model.Filter.RadiusKm ?? 10;

    // Gelişmiş filtrelerden herhangi biri aktifse panelin açık kalmasını sağlayan yardımcı metot
    bool HasAdvancedFilter(GetPublicListingsQuery f) =>
        f.Heating.HasValue || f.Internet.HasValue || f.Furnished == true ||
        f.Parking == true || f.Balcony == true || f.MaxDues.HasValue || f.MinBedrooms.HasValue;
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css" />

<section class="browse-hero">
    <div class="container">
        <span class="eyebrow">@L["İstanbul property, curated"]</span>
        @* The emphasised word is a placeholder rather than markup baked into the sentence:
           it lands in a different place in Turkish, and only the translator knows where. *@
        <h1>@Html.Raw(L["Find the place that {0} like yours.", $"<em>{L["feels"].Value}</em>"])</h1>
        <p class="lead">@L["Verified listings from local agents — filter by area, type, and price to find your next home."]</p>

        <div class="console-wrap rise d1">
            <form asp-action="Index" method="get">
                <div class="console">
                    <div class="field">
                        <label>@L["Location"]</label>
                        <input name="Keyword" value="@Model.Filter.Keyword" placeholder="@L["Neighbourhood or address"]" />
                    </div>
                    <div class="field">
                        <label>@L["Type"]</label>
                        <select name="ListingType">
                            <option value="">@L["Any type"]</option>
                            @foreach (var t in Enum.GetValues<ListingType>())
                            {
                                <option value="@t" selected="@(Model.Filter.ListingType == t)">@L.Localize(t)</option>
                            }
                        </select>
                    </div>
                    <div class="field">
                        <label>@L["Property"]</label>
                        <select name="PropertyType">
                            <option value="">@L["Any property"]</option>
                            @foreach (var p in Enum.GetValues<PropertyType>())
                            {
                                <option value="@p" selected="@(Model.Filter.PropertyType == p)">@L.Localize(p)</option>
                            }
                        </select>
                    </div>
                    <div class="field">
                        <label>@L["Max price"]</label>
                        <input name="MaxPrice" value="@Model.Filter.MaxPrice" placeholder="@L["Any"]" />
                    </div>
                    <div class="search-cell">
                        <button type="submit" class="btn btn-primary">@L["Search"]</button>
                    </div>
                </div>

                @* Gelişmiş Filtreler Paneli *@
                <details class="more-filters" @(HasAdvancedFilter(Model.Filter) ? "open" : "")>
                    <summary>@L["More filters"]</summary>
                    <div class="filter-grid">
                        <div class="mb-field">
                            <label class="form-label">@L["Heating"]</label>
                            <select name="Heating" class="form-select">
                                <option value="">@L["Any"]</option>
                                @foreach (var h in Enum.GetValues<RealEstatePortal.Domain.Enums.HeatingType>())
                                {
                                    <option value="@h" selected="@(Model.Filter.Heating == h)">@L.Localize(h)</option>
                                }
                            </select>
                        </div>
                        <div class="mb-field">
                            <label class="form-label">@L["Internet"]</label>
                            <select name="Internet" class="form-select">
                                <option value="">@L["Any"]</option>
                                @foreach (var i in Enum.GetValues<RealEstatePortal.Domain.Enums.InternetInfrastructure>())
                                {
                                    <option value="@i" selected="@(Model.Filter.Internet == i)">@L.Localize(i)</option>
                                }
                            </select>
                        </div>
                        <div class="mb-field">
                            <label class="form-label">@L["Min bedrooms"]</label>
                            <input name="MinBedrooms" value="@Model.Filter.MinBedrooms" class="form-control" placeholder="@L["Any"]" />
                        </div>
                        <div class="mb-field">
                            <label class="form-label">@L["Max monthly dues"]</label>
                            <input name="MaxDues" value="@Model.Filter.MaxDues" class="form-control" placeholder="@L["Any"]" />
                        </div>
                    </div>
                    <div class="filter-checks">
                        <label><input type="checkbox" name="Furnished" value="true" @(Model.Filter.Furnished == true ? "checked" : "") /> @L["Furnished"]</label>
                        <label><input type="checkbox" name="Parking" value="true" @(Model.Filter.Parking == true ? "checked" : "") /> @L["Parking"]</label>
                        <label><input type="checkbox" name="Balcony" value="true" @(Model.Filter.Balcony == true ? "checked" : "") /> @L["Balcony"]</label>
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm" style="margin-top:1rem;">@L["Apply filters"]</button>
                </details>

                @if (hasCenter)
                {
                    <input type="hidden" name="CenterLat" value="@Model.Filter.CenterLat" />
                    <input type="hidden" name="CenterLng" value="@Model.Filter.CenterLng" />
                    <input type="hidden" name="RadiusKm" value="@Model.Filter.RadiusKm" />
                }
            </form>
        </div>
    </div>
</section>

<section class="listings-sec">
    <div class="container">
        <div class="map-bar">
            @if (User.Identity is not null && User.Identity.IsAuthenticated)
            {
                <form asp-controller="SavedSearches" asp-action="Create" method="post"
                      style="display:flex;gap:.6rem;align-items:center;margin-bottom:1.5rem;flex-wrap:wrap;">
                    <input type="hidden" name="Keyword" value="@Model.Filter.Keyword" />
                    <input type="hidden" name="ListingType" value="@Model.Filter.ListingType" />
                    <input type="hidden" name="PropertyType" value="@Model.Filter.PropertyType" />
                    <input type="hidden" name="MaxPrice" value="@Model.Filter.MaxPrice" />
                    <input type="hidden" name="MinBedrooms" value="@Model.Filter.MinBedrooms" />
                    <input name="Name" class="form-control" style="max-width:260px;" placeholder="@L["Name this search (e.g. Kadıköy flats)"]" />
                    <button type="submit" class="btn btn-ghost btn-sm">🔔 @L["Save this search"]</button>
                </form>
            }
            <label>@L["Search on the map:"]</label>
            <select id="radiusSelect" class="form-select select-inline">
                @foreach (var km in new[] { 1, 5, 10, 25, 50 })
                {
                    <option value="@km" selected="@(currentRadius == km)">@km km</option>
                }
            </select>
            <button type="button" id="searchAreaBtn" class="btn btn-ghost btn-sm">@L["Search this area"]</button>
            @if (hasCenter)
            {
                <a class="btn btn-ghost btn-sm" asp-action="Index" asp-all-route-data="routeData">@L["Clear area"]</a>
                <span class="note">@L["Within {0} km of the marked area.", currentRadius]</span>
            }
            else
            {
                <span class="note">@L["Pan the map, then search its current area."]</span>
            }
        </div>

        <div id="browseMap"></div>

        <div class="sec-head">
            <h2>@L["Homes on the market"]</h2>
            <div class="sec-head-right">
                <select id="sortSelect" class="form-select select-inline" onchange="applySort(this.value)" aria-label="@L["Sort listings"]">
                    <option value="Newest" selected="@(Model.Filter.Sort == ListingSort.Newest)">@L["Newest"]</option>
                    <option value="PriceAsc" selected="@(Model.Filter.Sort == ListingSort.PriceAsc)">@L["Price: low to high"]</option>
                    <option value="PriceDesc" selected="@(Model.Filter.Sort == ListingSort.PriceDesc)">@L["Price: high to low"]</option>
                    <option value="AreaDesc" selected="@(Model.Filter.Sort == ListingSort.AreaDesc)">@L["Area: largest first"]</option>
                </select>
                @* Two keys rather than one with a suffix: English needs the plural "s",
                   Turkish never adds anything after a number. *@
                <span class="count">
                    @(Model.Listings.TotalCount == 1
                        ? L["{0} listing", Model.Listings.TotalCount]
                        : L["{0} listings", Model.Listings.TotalCount])
                </span>
            </div>
        </div>

        @if (!Model.Listings.Items.Any())
        {
            <div class="empty-state">
                <span class="value">@L["No matches"]</span>
                @L["Try widening your filters or clearing the map area."]
            </div>
        }
        else
        {
            <div class="card-grid">
                @foreach (var listing in Model.Listings.Items)
                {
                    <a class="listing-card rise d1" href="@Url.ListingUrl(listing.Id, listing.Slug)">
                        <div class="lc-media">
                            @if (User.Identity is not null && User.Identity.IsAuthenticated)
                            {
                                <button type="button"
                                        class="lc-fav @(listing.IsFavorited ? "is-fav" : "")"
                                        data-listing-id="@listing.Id"
                                        aria-label="@L["Save listing"]"
                                        onclick="toggleFav(event, this)">
                                    @(listing.IsFavorited ? "♥" : "♡")
                                </button>
                            }
                            <span class="lc-tag @(listing.ListingType == ListingType.Rent ? "rent" : "")">@L.Localize(listing.ListingType)</span>
                            @{ var cover = ListingImages.CoverOrPlaceholder(listing.CoverThumbnailUrl, listing.Id, Configuration.GetValue<bool>("Demo:PlaceholderImages")); }
                            @if (!string.IsNullOrEmpty(cover))
                            {
                                <img src="@cover" alt="@listing.Title" loading="lazy" />
                            }
                            else
                            {
                                <div class="noimg">@L["No photo yet"]</div>
                            }
                        </div>
                        <div class="lc-body">
                            <div class="lc-loc">@L.Localize(listing.PropertyType)</div>
                            <div class="lc-title">@listing.Title</div>
                            <div class="lc-meta">
                                <span><span class="value">@listing.Bedrooms</span> @L["bd"]</span>
                                <span><span class="value">@listing.AreaSqMeters.ToString("N0")</span> m²</span>
                            </div>
                            <div class="lc-price">
                                <span class="value">@listing.PriceAmount.ToString("N0") @listing.PriceCurrency</span>
                            </div>
                        </div>
                    </a>
                }
            </div>

            <nav class="pager">
                @if (Model.Listings.HasPreviousPage)
                {
                    <a asp-action="Index" asp-all-route-data="routeData" asp-route-pageNumber="@(Model.Listings.PageNumber - 1)">← @L["Prev"]</a>
                }
                else
                {
                    <span class="disabled">← @L["Prev"]</span>
                }
                <span class="current">@L["{0} of {1}", Model.Listings.PageNumber, Model.Listings.TotalPages]</span>
                @if (Model.Listings.HasNextPage)
                {
                    <a asp-action="Index" asp-all-route-data="routeData" asp-route-pageNumber="@(Model.Listings.PageNumber + 1)">@L["Next"] →</a>
                }
                else
                {
                    <span class="disabled">@L["Next"] →</span>
                }
            </nav>
        }
    </div>
    <form id="favToken" style="display:none;">@Html.AntiForgeryToken()</form>
</section>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js"></script>
    <script>
        (function () {
        var hasCenter = @(hasCenter ? "true" : "false");
        @if (hasCenter)
        {
            <text>
                var searchCenter = {
                lat: @Model.Filter.CenterLat!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture),
                lng: @Model.Filter.CenterLng!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)
                };
                var searchRadiusKm = @currentRadius;
            </text>
        }

        function esc(s){var d=document.createElement('div');d.textContent=s==null?'':s;return d.innerHTML;}

        var map = L.map('browseMap');
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19, attribution: '© OpenStreetMap contributors'
        }).addTo(map);

        // Cluster group keeps rendering cheap even with thousands of pins in view.
        var cluster = L.markerClusterGroup({ chunkedLoading: true });
        map.addLayer(cluster);

        if (hasCenter) {
        map.setView([searchCenter.lat, searchCenter.lng], 12);
        L.circle([searchCenter.lat, searchCenter.lng], {
        radius: searchRadiusKm * 1000, color:'#B08A4F', weight:1, fillColor:'#B08A4F', fillOpacity:.06
        }).addTo(map);
        } else {
        // Default to İstanbul; pins for whatever area the user pans to load on demand.
        map.setView([41.01, 28.97], 11);
        }

        // Carry the active list filters (keyword, type, price, …) into the pin request,
        // minus paging/area params the map manages itself.
        function baseFilterParams() {
        var params = new URLSearchParams(window.location.search);
        ['pageNumber', 'PageNumber', 'MinLat', 'MaxLat', 'MinLng', 'MaxLng'].forEach(function (k) {
        params.delete(k);
        });
        return params;
        }

        var reqToken = 0;
        function loadPins() {
        var b = map.getBounds();
        var params = baseFilterParams();
        params.set('MinLat', b.getSouth().toFixed(6));
        params.set('MaxLat', b.getNorth().toFixed(6));
        params.set('MinLng', b.getWest().toFixed(6));
        params.set('MaxLng', b.getEast().toFixed(6));

        var mine = ++reqToken;
        // Both URLs carry the page's own language: hardcoding one would cost a redirect on
        // every pan, and send the popup's link into the wrong language.
        var lang = document.documentElement.lang;
        fetch('/' + lang + '/Listings/MapPoints?' + params.toString())
        .then(function (r) { return r.json(); })
        .then(function (data) {
        if (mine !== reqToken) return; // a newer request already superseded this one
        cluster.clearLayers();
        var markers = data.map(function (p) {
        var m = L.marker([p.latitude, p.longitude]);
        m.bindPopup('<strong>' + esc(p.title) + '</strong><br/>' +
        esc(p.priceAmount.toLocaleString() + ' ' + p.priceCurrency) +
        '<br/><a href="/' + lang + '/listing/' + p.id + '/' + p.slug + '">' + @Html.Raw(Json.Serialize(L["View details"].Value)) + '</a>');
        return m;
        });
        cluster.addLayers(markers);
        })
        .catch(function () { /* leave existing pins on failure */ });
        }

        // Debounce so panning/zooming doesn't fire a request on every frame.
        var debounceTimer;
        map.on('moveend', function () {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(loadPins, 250);
        });
        loadPins();

        document.getElementById('searchAreaBtn').addEventListener('click', function () {
        var c = map.getCenter();
        var radius = document.getElementById('radiusSelect').value;
        var params = new URLSearchParams(window.location.search);
        params.set('CenterLat', c.lat.toFixed(6));
        params.set('CenterLng', c.lng.toFixed(6));
        params.set('RadiusKm', radius);
        params.set('pageNumber', '1');
        window.location = window.location.pathname + '?' + params.toString();
        });
        })();

        // Re-run the search with a new sort, keeping all current filters, from page 1.
        function applySort(value) {
        var params = new URLSearchParams(window.location.search);
        params.set('Sort', value);
        params.set('pageNumber', '1');
        window.location = window.location.pathname + '?' + params.toString();
        }

        function toggleFav(event, btn) {
        event.preventDefault();
        event.stopPropagation();
        // don't trigger the card's link
        var id = btn.getAttribute('data-listing-id');
        var token = document.querySelector('#favToken input[name="__RequestVerificationToken"]').value;

        // Must carry the language: the redirect that rescues bare URLs deliberately skips
        // POSTs (a redirect would drop the body), so an unprefixed POST just 404s.
        fetch('/' + document.documentElement.lang + '/Favorites/ToggleAjax', {
        method: 'POST',
        headers: { 'RequestVerificationToken': token, 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'listingId=' + encodeURIComponent(id)
        })
        .then(function (r) { return r.json(); })
        .then(function (d) {
        if (d.favorited) { btn.classList.add('is-fav'); btn.textContent = '♥'; }
        else { btn.classList.remove('is-fav'); btn.textContent = '♡'; }
        })
        .catch(function () { /* leave the heart unchanged on failure */ });
        }
    </script>
}