@using RealEstatePortal.Domain.Enums
@model RealEstatePortal.Application.Listings.Commands.CreateListing.CreateListingCommand
@{
    ViewData["Title"] = "New Listing";
}

<div class="form-page">
    <div class="container">
        <div class="form-shell">
            <span class="eyebrow">Agent dashboard</span>
            <h1 class="page-title" style="margin-bottom:1.5rem;">Create a listing</h1>

            <div class="form-card">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:1rem;"></div>

                    <div class="mb-field">
                        <label asp-for="Title" class="form-label"></label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                    <div class="mb-field">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                    <div class="form-row">
                        <div class="mb-field">
                            <label asp-for="ListingType" class="form-label"></label>
                            <select asp-for="ListingType" asp-items="Html.GetEnumSelectList<ListingType>()" class="form-select"></select>
                        </div>
                        <div class="mb-field">
                            <label asp-for="PropertyType" class="form-label"></label>
                            <select asp-for="PropertyType" asp-items="Html.GetEnumSelectList<PropertyType>()" class="form-select"></select>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="mb-field">
                            <label asp-for="Price" class="form-label"></label>
                            <input asp-for="Price" class="form-control" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                        <div class="mb-field">
                            <label asp-for="Currency" class="form-label"></label>
                            <input asp-for="Currency" class="form-control" />
                            <span asp-validation-for="Currency" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="form-row-3">
                        <div class="mb-field">
                            <label asp-for="Bedrooms" class="form-label"></label>
                            <input asp-for="Bedrooms" class="form-control" />
                            <span asp-validation-for="Bedrooms" class="text-danger"></span>
                        </div>
                        <div class="mb-field">
                            <label asp-for="Bathrooms" class="form-label"></label>
                            <input asp-for="Bathrooms" class="form-control" />
                            <span asp-validation-for="Bathrooms" class="text-danger"></span>
                        </div>
                        <div class="mb-field">
                            <label asp-for="AreaSqMeters" class="form-label"></label>
                            <input asp-for="AreaSqMeters" class="form-control" />
                            <span asp-validation-for="AreaSqMeters" class="text-danger"></span>
                        </div>
                    </div>

                    <h3 style="font-family:var(--serif);font-weight:600;font-size:1.2rem;margin:1.8rem 0 1rem;">Features &amp; details</h3>

                    <div class="form-row">
                        <div class="mb-field">
                            <label asp-for="Heating" class="form-label">Heating</label>
                            <select asp-for="Heating" asp-items="Html.GetEnumSelectList<RealEstatePortal.Domain.Enums.HeatingType>()" class="form-select">
                                <option value="">Not specified</option>
                            </select>
                        </div>
                        <div class="mb-field">
                            <label asp-for="Internet" class="form-label">Internet</label>
                            <select asp-for="Internet" asp-items="Html.GetEnumSelectList<RealEstatePortal.Domain.Enums.InternetInfrastructure>()" class="form-select">
                                <option value="">Not specified</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row-3">
                        <div class="mb-field">
                            <label asp-for="FloorNumber" class="form-label">Floor</label>
                            <input asp-for="FloorNumber" class="form-control" />
                        </div>
                        <div class="mb-field">
                            <label asp-for="TotalFloors" class="form-label">Total floors</label>
                            <input asp-for="TotalFloors" class="form-control" />
                        </div>
                        <div class="mb-field">
                            <label asp-for="BuildingAge" class="form-label">Building age (yrs)</label>
                            <input asp-for="BuildingAge" class="form-control" />
                        </div>
                    </div>

                    <div class="mb-field">
                        <label asp-for="MonthlyDues" class="form-label">Monthly dues (aidat)</label>
                        <input asp-for="MonthlyDues" class="form-control" />
                    </div>

                    <div style="display:flex;gap:1.5rem;flex-wrap:wrap;margin-bottom:.5rem;">
                        <label style="display:flex;align-items:center;gap:.5rem;">
                            <input type="checkbox" asp-for="IsFurnished" /> Furnished
                        </label>
                        <label style="display:flex;align-items:center;gap:.5rem;">
                            <input type="checkbox" asp-for="HasBalcony" /> Balcony
                        </label>
                        <label style="display:flex;align-items:center;gap:.5rem;">
                            <input type="checkbox" asp-for="HasParking" /> Parking / garage
                        </label>
                    </div>

                    <div class="mb-field">
                        <label asp-for="Address" class="form-label"></label>
                        <div class="input-with-btn">
                            <input asp-for="Address" class="form-control" />
                            <button type="button" class="btn btn-ghost" id="locateBtn">Locate on map</button>
                        </div>
                        <p class="form-hint">Type the address and click "Locate on map", then drag the pin to the exact spot.</p>
                    </div>

                    <input type="hidden" asp-for="Latitude" />
                    <input type="hidden" asp-for="Longitude" />
                    <div id="pickerMap"></div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Create listing</button>
                        <a asp-action="Mine" class="btn btn-ghost">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Head {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="~/js/location-picker.js"></script>
    <script>
        @{
            var initLat = Model.Latitude?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "null";
            var initLng = Model.Longitude?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "null";
        }
        initLocationPicker({
        mapId:'pickerMap', addressId:'Address', latId:'Latitude', lngId:'Longitude',
        locateBtnId:'locateBtn', initialLat:@initLat, initialLng:@initLng
        });
    </script>
}