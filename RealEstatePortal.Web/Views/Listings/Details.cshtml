@model RealEstatePortal.Web.Models.Listings.ListingDetailViewModel
@{
    ViewData["Title"] = Model.Listing.Title;
    var listing = Model.Listing;
}
@{
    // A plain-text, trimmed description for meta tags (~160 chars is the sweet spot).
    var metaDescription = listing.Description.Length > 160
        ? listing.Description.Substring(0, 157).TrimEnd() + "…"
        : listing.Description;
    var coverImage = listing.ImageUrls.FirstOrDefault();
    var canonicalUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/listing/{listing.Id}/{listing.Slug}";
}

@section Head {
    <meta name="description" content="@metaDescription" />
    <link rel="canonical" href="@canonicalUrl" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content="@listing.Title" />
    <meta property="og:description" content="@metaDescription" />
    <meta property="og:url" content="@canonicalUrl" />
    @if (coverImage is not null)
    {
        <meta property="og:image" content="@coverImage" />
    }
    <meta name="twitter:card" content="summary_large_image" />
}

<a asp-action="Index" class="btn btn-link px-0">← Back to listings</a>

@if (TempData["InquirySuccess"] is string ok)
{
    <div class="alert alert-success">@ok</div>
}

<h1>@listing.Title</h1>
<h3 class="text-muted">@listing.PriceAmount.ToString("N0") @listing.PriceCurrency</h3>

@if (listing.ImageUrls.Any())
{
    <div class="mb-4">
        <img id="mainImage" src="@listing.ImageUrls.First()" alt="@listing.Title"
             class="img-fluid rounded mb-2" style="width:100%; max-height:440px; object-fit:cover;" />
        @if (listing.ImageUrls.Count > 1)
        {
            <div class="d-flex flex-wrap gap-2">
                @foreach (var url in listing.ImageUrls)
                {
                    <img src="@url" class="img-thumbnail" style="height:72px; cursor:pointer;"
                         onclick="document.getElementById('mainImage').src='@url'" alt="thumbnail" />
                }
            </div>
        }
    </div>
}
@if (listing.Latitude is not null && listing.Longitude is not null)
{
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <h4>Location</h4>
    <div id="map" style="height: 320px;" class="mb-4 rounded border"></div>
}
<div class="row">
    <div class="col-md-7">
        <dl class="row">
            <dt class="col-sm-3">Type</dt>
            <dd class="col-sm-9">@listing.ListingType</dd>
            <dt class="col-sm-3">Property</dt>
            <dd class="col-sm-9">@listing.PropertyType</dd>
            <dt class="col-sm-3">Bedrooms</dt>
            <dd class="col-sm-9">@listing.Bedrooms</dd>
            <dt class="col-sm-3">Bathrooms</dt>
            <dd class="col-sm-9">@listing.Bathrooms</dd>
            <dt class="col-sm-3">Area</dt>
            <dd class="col-sm-9">@listing.AreaSqMeters.ToString("N0") m²</dd>
            <dt class="col-sm-3">Address</dt>
            <dd class="col-sm-9">@listing.Address</dd>
        </dl>

        <h4>Description</h4>
        <p>@listing.Description</p>
    </div>

    <div class="col-md-5">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Contact the agent</h5>
                <form asp-action="Inquire" method="post">
                    <input type="hidden" asp-for="Inquiry.ListingId" />
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-2">
                        <label asp-for="Inquiry.Name" class="form-label">Name</label>
                        <input asp-for="Inquiry.Name" class="form-control" />
                        <span asp-validation-for="Inquiry.Name" class="text-danger"></span>
                    </div>
                    <div class="mb-2">
                        <label asp-for="Inquiry.Email" class="form-label">Email</label>
                        <input asp-for="Inquiry.Email" class="form-control" />
                        <span asp-validation-for="Inquiry.Email" class="text-danger"></span>
                    </div>
                    <div class="mb-2">
                        <label asp-for="Inquiry.Phone" class="form-label">Phone (optional)</label>
                        <input asp-for="Inquiry.Phone" class="form-control" />
                        <span asp-validation-for="Inquiry.Phone" class="text-danger"></span>
                    </div>
                    <div class="mb-2">
                        <label asp-for="Inquiry.Message" class="form-label">Message</label>
                        <textarea asp-for="Inquiry.Message" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Inquiry.Message" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Send message</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    @if (listing.Latitude is not null && listing.Longitude is not null)
    {
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
        <script>
            (function () {
            var lat = @listing.Latitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture);
            var lng = @listing.Longitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture);
            var map = L.map('map').setView([lat, lng], 15);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '© OpenStreetMap contributors'
            }).addTo(map);
            L.marker([lat, lng]).addTo(map);
            })();
        </script>
    }
}
@{
    var propertyTypeSchema = listing.PropertyType switch
    {
        RealEstatePortal.Domain.Enums.PropertyType.Apartment => "Apartment",
        RealEstatePortal.Domain.Enums.PropertyType.House => "House",
        _ => "Residence"
    };

    var structuredData = new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = propertyTypeSchema,
        ["name"] = listing.Title,
        ["description"] = metaDescription,
        ["url"] = canonicalUrl,
        ["numberOfBedrooms"] = listing.Bedrooms,
        ["numberOfBathroomsTotal"] = listing.Bathrooms,
        ["floorSize"] = new Dictionary<string, object?>
        {
            ["@type"] = "QuantitativeValue",
            ["value"] = listing.AreaSqMeters,
            ["unitCode"] = "MTK"   // square metre
        },
        ["image"] = listing.ImageUrls,
        ["offers"] = new Dictionary<string, object?>
        {
            ["@type"] = "Offer",
            ["price"] = listing.PriceAmount,
            ["priceCurrency"] = listing.PriceCurrency,
            ["availability"] = "https://schema.org/InStock"
        }
    };
    var jsonLd = System.Text.Json.JsonSerializer.Serialize(structuredData);
}

<script type="application/ld+json">
    @Html.Raw(jsonLd)
</script>