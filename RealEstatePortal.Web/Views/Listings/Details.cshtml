@model RealEstatePortal.Web.Models.Listings.ListingDetailViewModel
@{
    var listing = Model.Listing;
    ViewData["Title"] = listing.Title;

    var metaDescription = listing.Description.Length > 160
        ? listing.Description.Substring(0, 157).TrimEnd() + "…"
        : listing.Description;
    var coverImage = listing.ImageUrls.FirstOrDefault();
    var canonicalUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/listing/{listing.Id}/{listing.Slug}";
}

@section Head {
    <meta name="description" content="@metaDescription" />
    <link rel="canonical" href="@canonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="@listing.Title" />
    <meta property="og:description" content="@metaDescription" />
    <meta property="og:url" content="@canonicalUrl" />
    @if (coverImage is not null)
    {
        <meta property="og:image" content="@coverImage" />
    }
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
}

<div class="detail">
    <div class="container">
        <a class="back-link" asp-action="Index">← Back to listings</a>

        @if (TempData["InquirySuccess"] is string ok)
        {
            <div class="alert alert-success" style="margin-bottom:1.5rem;">@ok</div>
        }

        @if (listing.ImageUrls.Any())
        {
            <div class="gallery">
                <div class="gallery-main">
                    <img id="mainImage" src="@listing.ImageUrls.First()" alt="@listing.Title" />
                </div>
                @if (listing.ImageUrls.Count > 1)
                {
                    <div class="gallery-thumbs">
                        @for (var i = 0; i < listing.ImageUrls.Count; i++)
                        {
                            <img src="@listing.ImageUrls[i]" class="@(i == 0 ? "active" : "")"
                                 onclick="selectImage(this, '@listing.ImageUrls[i]')" alt="thumbnail" />
                        }
                    </div>
                }
            </div>
        }
        else if (Configuration.GetValue<bool>("Demo:PlaceholderImages"))
        {
            var seeds = ListingImages.PlaceholderSeeds(listing.Id, 5);
            <div class="gallery">
                <div class="gallery-main">
                    <img id="mainImage" src="https://loremflickr.com/1200/800/house,apartment?lock=@seeds[0]" alt="@listing.Title" />
                </div>
                <div class="gallery-thumbs">
                    @for (var i = 0; i < seeds.Count; i++)
                    {
                        <img src="https://loremflickr.com/300/200/house,apartment?lock=@seeds[i]"
                             class="@(i == 0 ? "active" : "")"
                             onclick="selectImage(this, 'https://loremflickr.com/1200/800/house,apartment?lock=@seeds[i]')"
                             alt="thumbnail" loading="lazy" />
                    }
                </div>
            </div>
        }
        else
        {
            <div class="gallery-none">No photos yet</div>
        }

        <div class="detail-grid">
            <div>
                <div class="detail-head">
                    <span class="eyebrow">@listing.PropertyType · @listing.ListingType</span>
                    <h1>@listing.Title</h1>
                    <div class="detail-price">@listing.PriceAmount.ToString("N0") @listing.PriceCurrency</div>
                    @if (User.Identity is not null && User.Identity.IsAuthenticated)
                    {
                        <form asp-controller="Favorites" asp-action="Toggle" method="post" style="margin-bottom:1.5rem;">
                            <input type="hidden" name="listingId" value="@listing.Id" />
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                            <button type="submit" class="btn @(Model.IsFavorited ? "btn-primary" : "btn-ghost")">
                                @(Model.IsFavorited ? "♥ Saved" : "♡ Save to favorites")
                            </button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn btn-ghost" style="margin-bottom:1.5rem;">♡ Sign in to save</a>
                    }
                </div>

                <div class="facts">
                    <div class="fact"><span class="value">@listing.Bedrooms</span><span class="lbl">Bedrooms</span></div>
                    <div class="fact"><span class="value">@listing.Bathrooms</span><span class="lbl">Bathrooms</span></div>
                    <div class="fact"><span class="value">@listing.AreaSqMeters.ToString("N0")</span><span class="lbl">m² area</span></div>
                    <div class="fact"><span class="value" style="font-size:1.05rem;">@listing.ListingType</span><span class="lbl">Listing</span></div>
                </div>

                <div class="detail-section">
                    <h3>Features</h3>
                    <div class="feature-list">
                        @if (listing.Heating is not null && listing.Heating != RealEstatePortal.Domain.Enums.HeatingType.None)
                        {
                            <div class="feature"><span class="fk">Heating</span><span class="fv">@listing.Heating</span></div>
                        }
                        @if (listing.Internet is not null && listing.Internet != RealEstatePortal.Domain.Enums.InternetInfrastructure.Unknown)
                        {
                            <div class="feature"><span class="fk">Internet</span><span class="fv">@listing.Internet</span></div>
                        }
                        @if (listing.FloorNumber is not null)
                        {
                            <div class="feature"><span class="fk">Floor</span><span class="fv value">@listing.FloorNumber@(listing.TotalFloors is not null ? $" / {listing.TotalFloors}" : "")</span></div>
                        }
                        @if (listing.BuildingAge is not null)
                        {
                            <div class="feature"><span class="fk">Building age</span><span class="fv"><span class="value">@listing.BuildingAge</span> yrs</span></div>
                        }
                        @if (listing.MonthlyDues is not null)
                        {
                            <div class="feature"><span class="fk">Monthly dues</span><span class="fv"><span class="value">@listing.MonthlyDues.Value.ToString("N0")</span> @listing.PriceCurrency</span></div>
                        }
                        <div class="feature"><span class="fk">Furnished</span><span class="fv">@(listing.IsFurnished ? "Yes" : "No")</span></div>
                        <div class="feature"><span class="fk">Balcony</span><span class="fv">@(listing.HasBalcony ? "Yes" : "No")</span></div>
                        <div class="feature"><span class="fk">Parking</span><span class="fv">@(listing.HasParking ? "Yes" : "No")</span></div>
                    </div>
                </div>

                <div class="detail-section">
                    <h3>About this property</h3>
                    <p class="detail-desc">@listing.Description</p>
                </div>

                <!-- YENİ: EMLAKÇI PROFİL KARTI BURAYA EKLENDİ -->
                @if (!string.IsNullOrEmpty(listing.OwnerId))
                {
                    <a class="listed-by" asp-controller="Agent" asp-action="Index" asp-route-id="@listing.OwnerId" style="text-decoration: none; display: flex; align-items: center; gap: 1rem; margin: 2rem 0; padding: 1rem; border: 1px solid #eee; border-radius: 8px;">
                        <div class="lb-avatar" style="width: 48px; height: 48px; border-radius: 50%; overflow: hidden; background: #eee; display: flex; align-items: center; justify-content: center; font-weight: bold; color: #555;">
                            @if (listing.OwnerAvatarUrl is not null)
                            {
                                <img src="@listing.OwnerAvatarUrl" alt="@listing.OwnerName" style="width: 100%; height: 100%; object-fit: cover;" />
                            }
                            else
                            {
                                <span>@((listing.OwnerName ?? "A").Substring(0, 1).ToUpper())</span>
                            }
                        </div>
                        <div>
                            <div class="lb-label" style="font-size: 0.85rem; color: #888;">Listed by</div>
                            <div class="lb-name" style="font-weight: 600; color: #333;">@(listing.OwnerName ?? "Agent")</div>
                        </div>
                    </a>
                }

                <div class="detail-section">
                    <h3>Location</h3>
                    <p class="addr-line">@listing.Address</p>
                    @if (listing.Latitude is not null && listing.Longitude is not null)
                    {
                        <div id="detailMap"></div>
                    }
                </div>
            </div>

            <aside>
                <div class="contact-card">
                    <h3>Contact the agent</h3>
                    <p class="sub">Interested? Send a message and the agent will get back to you.</p>
                    <form asp-action="Inquire" method="post">
                        <input type="hidden" asp-for="Inquiry.ListingId" />
                        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:.8rem;"></div>

                        <div class="field-group">
                            <label asp-for="Inquiry.Name" class="form-label">Name</label>
                            <input asp-for="Inquiry.Name" class="form-control" />
                            <span asp-validation-for="Inquiry.Name" class="text-danger"></span>
                        </div>
                        <div class="field-group">
                            <label asp-for="Inquiry.Email" class="form-label">Email</label>
                            <input asp-for="Inquiry.Email" class="form-control" />
                            <span asp-validation-for="Inquiry.Email" class="text-danger"></span>
                        </div>
                        <div class="field-group">
                            <label asp-for="Inquiry.Phone" class="form-label">Phone (optional)</label>
                            <input asp-for="Inquiry.Phone" class="form-control" />
                            <span asp-validation-for="Inquiry.Phone" class="text-danger"></span>
                        </div>
                        <div class="field-group">
                            <label asp-for="Inquiry.Message" class="form-label">Message</label>
                            <textarea asp-for="Inquiry.Message" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Inquiry.Message" class="text-danger"></span>
                        </div>
                        <button type="submit" class="btn btn-primary" style="width:100%;">Send message</button>
                    </form>
                </div>
            </aside>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function selectImage(el, url){
            document.getElementById('mainImage').src = url;
            document.querySelectorAll('.gallery-thumbs img').forEach(function(t){t.classList.remove('active');});
            el.classList.add('active');
        }
    </script>
    @if (listing.Latitude is not null && listing.Longitude is not null)
    {
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
        <script>
            (function () {
            var lat = @listing.Latitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture);
            var lng = @listing.Longitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture);
            var map = L.map('detailMap').setView([lat, lng], 15);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19, attribution: '© OpenStreetMap contributors'
            }).addTo(map);
            L.marker([lat, lng]).addTo(map);
            })();
        </script>
    }

    @{
        var propertyTypeSchema = listing.PropertyType switch
        {
            RealEstatePortal.Domain.Enums.PropertyType.Apartment => "Apartment",
            RealEstatePortal.Domain.Enums.PropertyType.House => "House",
            _ => "Residence"
        };
        var structuredData = new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = propertyTypeSchema,
            ["name"] = listing.Title,
            ["description"] = metaDescription,
            ["url"] = canonicalUrl,
            ["numberOfBedrooms"] = listing.Bedrooms,
            ["numberOfBathroomsTotal"] = listing.Bathrooms,
            ["floorSize"] = new Dictionary<string, object?>
            {
                ["@type"] = "QuantitativeValue",
                ["value"] = listing.AreaSqMeters,
                ["unitCode"] = "MTK"
            },
            ["image"] = listing.ImageUrls,
            ["offers"] = new Dictionary<string, object?>
            {
                ["@type"] = "Offer",
                ["price"] = listing.PriceAmount,
                ["priceCurrency"] = listing.PriceCurrency,
                ["availability"] = "https://schema.org/InStock"
            }
        };
        var jsonLd = System.Text.Json.JsonSerializer.Serialize(structuredData);
    }
    <script type="application/ld+json">@Html.Raw(jsonLd)</script>
}