@using RealEstatePortal.Domain.Enums
@model RealEstatePortal.Application.Listings.Commands.UpdateListing.UpdateListingCommand
@{
    ViewData["Title"] = "Edit Listing";
    var photos = ViewBag.Photos as List<RealEstatePortal.Application.Listings.Queries.GetListingImages.ListingImageDto>
                 ?? new List<RealEstatePortal.Application.Listings.Queries.GetListingImages.ListingImageDto>();
}

<h1>Edit Listing</h1>

<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ListingType" class="form-label"></label>
                <select asp-for="ListingType" asp-items="Html.GetEnumSelectList<ListingType>()" class="form-select"></select>
            </div>
            <div class="mb-3">
                <label asp-for="PropertyType" class="form-label"></label>
                <select asp-for="PropertyType" asp-items="Html.GetEnumSelectList<PropertyType>()" class="form-select"></select>
            </div>
            <div class="row">
                <div class="col mb-3">
                    <label asp-for="Price" class="form-label"></label>
                    <input asp-for="Price" class="form-control" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
                <div class="col mb-3">
                    <label asp-for="Currency" class="form-label"></label>
                    <input asp-for="Currency" class="form-control" />
                    <span asp-validation-for="Currency" class="text-danger"></span>
                </div>
            </div>
            <div class="row">
                <div class="col mb-3">
                    <label asp-for="Bedrooms" class="form-label"></label>
                    <input asp-for="Bedrooms" class="form-control" />
                    <span asp-validation-for="Bedrooms" class="text-danger"></span>
                </div>
                <div class="col mb-3">
                    <label asp-for="Bathrooms" class="form-label"></label>
                    <input asp-for="Bathrooms" class="form-control" />
                    <span asp-validation-for="Bathrooms" class="text-danger"></span>
                </div>
                <div class="col mb-3">
                    <label asp-for="AreaSqMeters" class="form-label"></label>
                    <input asp-for="AreaSqMeters" class="form-control" />
                    <span asp-validation-for="AreaSqMeters" class="text-danger"></span>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Address" class="form-label"></label>
                <input asp-for="Address" class="form-control" />
            </div>

            <hr />
            <h4>Add photos</h4>
            <div class="mb-3">
                <label class="form-label">Select images (uploaded when you click Save)</label>
                <input type="file" name="newPhotos" multiple accept="image/*" class="form-control" id="newPhotos" />
                <div id="previewArea" class="row mt-2"></div>
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Mine" class="btn btn-secondary">Cancel</a>
        </form>

        <hr />
        <h4>Current photos</h4>
        @if (photos.Any())
        {
            <div class="row">
                @foreach (var photo in photos)
                {
                    <div class="col-auto mb-3 text-center">
                        <img src="@photo.ThumbnailUrl" alt="listing photo" class="img-thumbnail" style="height:120px;" />
                        <div class="mt-1">
                            @if (photo.IsCover)
                            {
                                <span class="badge bg-primary">Cover</span>
                            }
                            else
                            {
                                <form asp-action="SetCover" method="post" class="d-inline">
                                    <input type="hidden" name="listingId" value="@Model.Id" />
                                    <input type="hidden" name="imageId" value="@photo.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">Set cover</button>
                                </form>
                            }
                            <form asp-action="DeletePhoto" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this photo? This cannot be undone.');">
                                <input type="hidden" name="listingId" value="@Model.Id" />
                                <input type="hidden" name="imageId" value="@photo.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">✕</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-muted">No photos yet.</p>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('newPhotos').addEventListener('change', function (e) {
            const area = document.getElementById('previewArea');
            area.innerHTML = '';
            for (const file of e.target.files) {
                if (!file.type.startsWith('image/')) continue;
                const col = document.createElement('div');
                col.className = 'col-auto mb-2';
                const img = document.createElement('img');
                img.className = 'img-thumbnail';
                img.style.height = '90px';
                img.style.opacity = '0.7';
                img.src = URL.createObjectURL(file);
                col.appendChild(img);
                area.appendChild(col);
            }
        });
    </script>
}