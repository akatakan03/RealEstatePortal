@model RealEstatePortal.Application.Listings.Commands.UpdateListing.UpdateListingCommand
@{
    ViewData["Title"] = "Delete Listing";
}

<h1>Delete Listing</h1>
<p class="text-danger">Are you sure you want to delete this listing? This cannot be undone.</p>

<dl class="row">
    <dt class="col-sm-3">Title</dt>
    <dd class="col-sm-9">@Model.Title</dd>
    <dt class="col-sm-3">Type</dt>
    <dd class="col-sm-9">@Model.ListingType</dd>
    <dt class="col-sm-3">Property</dt>
    <dd class="col-sm-9">@Model.PropertyType</dd>
    <dt class="col-sm-3">Price</dt>
    <dd class="col-sm-9">@Model.Price.ToString("N0") @Model.Currency</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Mine" class="btn btn-secondary">Cancel</a>
</form>