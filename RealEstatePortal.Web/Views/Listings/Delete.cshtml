@model RealEstatePortal.Application.Listings.Commands.UpdateListing.UpdateListingCommand
@{
    ViewData["Title"] = "Delete Listing";
}

<div class="form-page">
    <div class="container">
        <div class="form-shell narrow">
            <span class="eyebrow">Agent dashboard</span>
            <h1 class="page-title" style="margin-bottom:1rem;">Delete listing</h1>

            <div class="form-card">
                <div class="alert alert-danger" style="margin-bottom:1.4rem;">
                    This will permanently delete the listing and its photos. This can't be undone.
                </div>

                <dl style="display:grid;grid-template-columns:auto 1fr;gap:.6rem 1.2rem;margin:0 0 1.5rem;">
                    <dt style="color:var(--muted);">Title</dt>
                    <dd style="margin:0;font-weight:600;">@Model.Title</dd>
                    <dt style="color:var(--muted);">Type</dt>
                    <dd style="margin:0;">@Model.ListingType</dd>
                    <dt style="color:var(--muted);">Property</dt>
                    <dd style="margin:0;">@Model.PropertyType</dd>
                    <dt style="color:var(--muted);">Price</dt>
                    <dd style="margin:0;"><span class="value">@Model.Price.ToString("N0") @Model.Currency</span></dd>
                </dl>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="form-actions" style="margin-top:0;padding-top:0;border-top:none;">
                        <button type="submit" class="btn btn-danger">Delete permanently</button>
                        <a asp-action="Mine" class="btn btn-ghost">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>