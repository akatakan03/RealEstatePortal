@model RealEstatePortal.Application.Listings.Commands.UpdateListing.UpdateListingCommand
@{
    ViewData["Title"] = "Delete Listing";
}

<div class="form-page">
    <div class="container">
        <div class="form-shell narrow">
            <span class="eyebrow">Agent dashboard</span>
            <h1 class="page-title" style="margin-bottom:1rem;">Delete listing</h1>

            <div class="form-card">
                <div class="alert alert-danger">
                    This will permanently delete the listing and its photos. This can't be undone.
                </div>

                <dl class="summary-grid">
                    <dt>Title</dt>
                    <dd class="strong">@Model.Title</dd>
                    <dt>Type</dt>
                    <dd>@Model.ListingType</dd>
                    <dt>Property</dt>
                    <dd>@Model.PropertyType</dd>
                    <dt>Price</dt>
                    <dd><span class="value">@Model.Price.ToString("N0") @Model.Currency</span></dd>
                </dl>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="form-actions bare">
                        <button type="submit" class="btn btn-danger">Delete permanently</button>
                        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-ghost">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>