@using System.Globalization
@using RealEstatePortal.Application.Common.Analytics
@model (IReadOnlyList<DailyCountDto> Points, string Title, string Series, string Plural, string Singular)
@{
    var inv = CultureInfo.InvariantCulture;
    var pts = Model.Points;
    var peak = pts.Count > 0 ? pts.Max(p => p.Count) : 0;
    var scale = Math.Max(peak, 1);
    // The window and its total both come off the points, so the heading, the screen-reader
    // label and the bars can never quote different numbers for the same chart.
    var total = pts.Sum(p => p.Count);
    var sub = $"last {pts.Count} days · {total.ToString("N0", inv)} total";

    string Noun(int n) => n == 1 ? Model.Singular : Model.Plural;
}

<div class="dash-card">
    <div class="dash-card-head">
        <h2>@Model.Title</h2>
        <span class="dash-card-sub">@sub</span>
    </div>

    <div class="chart">
        @* y-axis carries the peak; every other value is in the tooltip and the table view *@
        <div class="chart-y">
            <span>@peak.ToString("N0")</span>
            <span>0</span>
        </div>
        <div class="chart-plot">
            <div class="trend trend-@Model.Series" role="img"
                 aria-label="Daily @Model.Plural over the last @pts.Count days, @total in total">
                @foreach (var d in pts)
                {
                    var pct = (d.Count * 100.0 / scale).ToString("0.##", inv);
                    <div class="trend-bar" style="height:@pct%"
                         title="@d.Date.ToString("MMM d", inv): @d.Count @Noun(d.Count)"></div>
                }
            </div>
            <div class="chart-x">
                <span>@(pts.Count > 0 ? pts[0].Date.ToString("MMM d", inv) : "")</span>
                <span>@(pts.Count > 0 ? pts[pts.Count - 1].Date.ToString("MMM d", inv) : "")</span>
            </div>
        </div>
    </div>

    <details class="chart-table">
        <summary>Table view</summary>
        <div class="table-scroll">
            <table class="stats-table">
                <thead><tr><th>Day</th><th class="num">@Model.Plural</th></tr></thead>
                <tbody>
                    @foreach (var d in pts)
                    {
                        <tr>
                            <td>@d.Date.ToString("MMM d, yyyy", inv)</td>
                            <td class="num">@d.Count.ToString("N0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </details>
</div>
