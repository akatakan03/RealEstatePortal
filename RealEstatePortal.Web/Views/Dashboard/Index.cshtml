@using System.Globalization
@using RealEstatePortal.Domain.Enums
@model RealEstatePortal.Application.Agents.Queries.GetAgentDashboard.AgentDashboardDto
@{
    ViewData["Title"] = L["Dashboard"].Value;
    var inv = CultureInfo.InvariantCulture;

    var status = ViewBag.Status as ListingStatus?;
    var locked = ViewBag.Locked is true;
    var search = ViewBag.Search as string;
    var noFilter = status is null && !locked;

    var viewsDelta = TrendDelta.Between(Model.Views7d, Model.ViewsPrev7d);
    var inqDelta = TrendDelta.Between(Model.Inquiries7d, Model.InquiriesPrev7d);
    var favDelta = TrendDelta.Between(Model.Favorites7d, Model.FavoritesPrev7d);
}

<section class="dash-sec">
    <div class="container">
        <div class="dash-hero">
            <div>
                <h1>@L["Dashboard"]</h1>
                <p class="lead">@L["How your listings are performing."]</p>
            </div>
            <a class="btn btn-primary" asp-controller="Listings" asp-action="Create">+ @L["New listing"]</a>
        </div>

        @if (TempData["UnlockRequested"] is string sent)
        {
            <div class="alert alert-success">@sent</div>
        }

        @if (Model.TotalListings == 0)
        {
            <div class="empty-state">
                <span class="value">@L["No listings yet"]</span>
                @L["Once you publish a listing, its views and inquiries will show up here."]
                <div style="margin-top:1rem;"><a class="btn btn-primary" asp-controller="Listings" asp-action="Create">@L["Create a listing"]</a></div>
            </div>
        }
        else
        {
            <div class="kpi-row">
                <div class="kpi">
                    <div class="kpi-label">@L["Total views"]</div>
                    <div class="kpi-value">@Model.TotalViews.ToString("N0")</div>
                </div>
                <div class="kpi">
                    <div class="kpi-label" title="@L["Distinct visitors over the last 30 days. One person who opened several of your listings counts once."]">@L["Unique visitors · 30 days"]</div>
                    <div class="kpi-value">@Model.UniqueVisitors.ToString("N0")</div>
                </div>
                <div class="kpi">
                    <div class="kpi-label">@L["Views · 7 days"]</div>
                    <div class="kpi-value">@Model.Views7d.ToString("N0")</div>
                    <div class="kpi-delta @viewsDelta.Css">
                        <span aria-hidden="true">@viewsDelta.Arrow</span> @L[viewsDelta.Text]
                        <span class="kpi-delta-note">@L["vs previous 7 days"]</span>
                    </div>
                </div>
                <div class="kpi">
                    <div class="kpi-label">@L["Views · 30 days"]</div>
                    <div class="kpi-value">@Model.Views30d.ToString("N0")</div>
                </div>
                <div class="kpi">
                    <div class="kpi-label">@L["Inquiries · 7 days"]</div>
                    <div class="kpi-value">
                        <a asp-controller="Inquiries" asp-action="Index" style="color:inherit;">@Model.Inquiries7d.ToString("N0")</a>
                    </div>
                    <div class="kpi-delta @inqDelta.Css">
                        <span aria-hidden="true">@inqDelta.Arrow</span> @L[inqDelta.Text]
                        <span class="kpi-delta-note">@L["vs previous 7 days · {0} all time", Model.TotalInquiries.ToString("N0")]</span>
                    </div>
                </div>
                <div class="kpi">
                    <div class="kpi-label" title="@L["People who saved one of your listings. Each person counts once per listing."]">@L["Saves · 7 days"]</div>
                    <div class="kpi-value">@Model.Favorites7d.ToString("N0")</div>
                    <div class="kpi-delta @favDelta.Css">
                        <span aria-hidden="true">@favDelta.Arrow</span> @L[favDelta.Text]
                        <span class="kpi-delta-note">@L["vs previous 7 days · {0} all time", Model.TotalFavorites.ToString("N0")]</span>
                    </div>
                </div>
                <div class="kpi">
                    <div class="kpi-label" title="@L["How many inquiries each 100 views produced over the last 30 days."]">@L["Inquiries / 100 views"]</div>
                    <div class="kpi-value">@Model.ConversionPer100.ToString("0.0", inv)</div>
                    <div class="kpi-delta flat"><span class="kpi-delta-note">@L["last 30 days"]</span></div>
                </div>
                <div class="kpi">
                    <div class="kpi-label">@L["Active listings"]</div>
                    <div class="kpi-value">@Model.ActiveListings / @Model.TotalListings</div>
                </div>
            </div>

            @* Two measures on very different scales get two charts — never one plot with two y-axes. *@
            <div class="chart-pair">
                @await Html.PartialAsync("_TrendChart",
                    (Model.ViewTrend, "Daily views", "views", "views", "view"))
                @await Html.PartialAsync("_TrendChart",
                    (Model.InquiryTrend, "Daily inquiries", "inquiries", "inquiries", "inquiry"))
            </div>

            <div class="dash-card">
                <div class="dash-card-head">
                    <h2>@L["Portfolio"]</h2>
                    <span class="dash-card-sub">@L["how your {0} listings break down", Model.TotalListings]</span>
                </div>
                <div class="breakdown-row">
                    @await Html.PartialAsync("_Breakdown", (Model.StatusBreakdown, "By status"))
                    @await Html.PartialAsync("_Breakdown", (Model.TypeBreakdown, "By listing type"))
                </div>
            </div>

            <div class="dash-card">
                <div class="dash-card-head">
                    <h2>@L["My listings"]</h2>
                    <span class="dash-card-sub">@L["newest first — open Stats for a listing's own numbers"]</span>
                </div>

                @* Filtering and paging happen on the server: a portfolio of any size renders
                   one page of rows, so the page stays light no matter how many listings exist. *@
                <div class="listing-toolbar">
                    <div class="filter-tabs" role="tablist">
                        <a class="filter-tab @(noFilter ? "is-active" : "")"
                           asp-action="Index" asp-route-search="@search">@L["All"] <span class="ft-count">@Model.TabCounts.All</span></a>
                        <a class="filter-tab @(!locked && status == ListingStatus.Active ? "is-active" : "")"
                           asp-action="Index" asp-route-status="@ListingStatus.Active" asp-route-search="@search">@L["Active"] <span class="ft-count">@Model.TabCounts.Active</span></a>
                        <a class="filter-tab @(!locked && status == ListingStatus.Draft ? "is-active" : "")"
                           asp-action="Index" asp-route-status="@ListingStatus.Draft" asp-route-search="@search">@L["Draft"] <span class="ft-count">@Model.TabCounts.Draft</span></a>
                        <a class="filter-tab @(!locked && status == ListingStatus.Archived ? "is-active" : "")"
                           asp-action="Index" asp-route-status="@ListingStatus.Archived" asp-route-search="@search">@L["Archived"] <span class="ft-count">@Model.TabCounts.Archived</span></a>
                        <a class="filter-tab @(locked ? "is-active" : "")"
                           asp-action="Index" asp-route-locked="true" asp-route-search="@search">@L["Locked"] <span class="ft-count">@Model.TabCounts.Locked</span></a>
                    </div>
                    <form method="get" asp-action="Index" class="listing-search-form">
                        <input type="hidden" name="status" value="@(status?.ToString())" />
                        <input type="hidden" name="locked" value="@locked.ToString().ToLowerInvariant()" />
                        <input type="search" name="search" value="@search" class="listing-search"
                               placeholder="@L["Search by title…"]" autocomplete="off" aria-label="@L["Search your listings by title"]" />
                        <button type="submit" class="btn btn-ghost btn-sm">@L["Search"]</button>
                    </form>
                </div>

                <div class="table-scroll">
                    <table class="stats-table listing-table" id="myListingsTable">
                        <thead>
                            <tr>
                                <th>@L["Listing"]</th>
                                <th>@L["Type"]</th>
                                <th class="num">@L["Price"]</th>
                                <th>@L["Status"]</th>
                                <th class="col-actions"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.Listings.Items)
                            {
                                var rowStatus = row.IsLocked ? "locked" : row.Status.ToString().ToLowerInvariant();
                                <tr>
                                    <td>
                                        <div class="listing-cell">
                                            @if (!string.IsNullOrEmpty(row.CoverThumbnailUrl))
                                            {
                                                <img class="listing-thumb" src="@row.CoverThumbnailUrl" alt=""
                                                     width="46" height="46" loading="lazy" decoding="async" />
                                            }
                                            else
                                            {
                                                <span class="listing-thumb listing-thumb-empty" aria-hidden="true">⌂</span>
                                            }
                                            @* Truncated to keep the row within the page width; the
                                               full title stays available on hover and to a reader. *@
                                            <a class="listing-cell-title" title="@row.Title"
                                               href="@Url.ListingUrl(row.Id, row.Slug)">@row.Title</a>
                                        </div>
                                    </td>
                                    <td>@L.Localize(row.ListingType)</td>
                                    <td class="num">@row.PriceAmount.ToString("N0") @row.PriceCurrency</td>
                                    <td>
                                        @if (row.IsLocked)
                                        {
                                            <span class="status-pill status-locked">🔒 @L["Locked"]</span>
                                        }
                                        else
                                        {
                                            <span class="status-pill status-@row.Status.ToString().ToLowerInvariant()">@L.Localize(row.Status)</span>
                                        }
                                    </td>
                                    <td class="col-actions">
                                        <div class="row-actions">
                                            @* Stats stay available on a locked listing — the agent
                                               still needs to see what it did before it was pulled. *@
                                            <button type="button" class="btn btn-ghost btn-sm" data-stats-for="@row.Id"
                                                    data-stats-title="@row.Title">@L["Stats"]</button>
                                            @if (!row.IsLocked)
                                            {
                                                @if (row.Status == ListingStatus.Active)
                                                {
                                                    <form asp-controller="Listings" asp-action="Archive" asp-route-id="@row.Id" method="post">
                                                        <button type="submit" class="btn btn-ghost btn-sm">@L["Archive"]</button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <form asp-controller="Listings" asp-action="Publish" asp-route-id="@row.Id" method="post">
                                                        <button type="submit" class="btn btn-primary btn-sm">@L["Publish"]</button>
                                                    </form>
                                                }
                                                <a asp-controller="Listings" asp-action="Edit" asp-route-id="@row.Id" class="btn btn-ghost btn-sm">@L["Edit"]</a>
                                                <a asp-controller="Listings" asp-action="Delete" asp-route-id="@row.Id" class="btn btn-danger btn-sm">@L["Delete"]</a>
                                            }
                                        </div>
                                    </td>
                                </tr>

                                @* The appeal form needs room to breathe, so it gets the full width
                                   under its listing instead of being crushed into the action cell. *@
                                if (row.IsLocked)
                                {
                                    <tr class="locked-row">
                                        <td colspan="5">
                                            <div class="locked-msg">
                                                <strong>@L["Locked by an administrator."]</strong>
                                                <span>@row.LockReason</span>
                                                @if (row.UnlockRequested)
                                                {
                                                    <small class="review-requested">⏳ @(row.UnlockRequestedAt is null
                                                        ? L["Re-review requested. An admin will take another look."]
                                                        : L["Re-review requested on {0}. An admin will take another look.", row.UnlockRequestedAt.Value.ToString("d")])</small>
                                                }
                                                else
                                                {
                                                    <details class="unlock-appeal">
                                                        <summary>@L["Fixed it — request re-review"]</summary>
                                                        <form asp-controller="Listings" asp-action="RequestUnlock" asp-route-id="@row.Id" method="post">
                                                            <textarea name="note" maxlength="1000" rows="3" placeholder="@L["Optional: tell the admin what you changed (e.g. replaced the photos)."]"></textarea>
                                                            <button type="submit" class="btn btn-primary btn-sm">@L["Send request"]</button>
                                                        </form>
                                                    </details>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                    @if (Model.Listings.TotalCount == 0)
                    {
                        <p class="no-match">@L["No listings match your filters."]</p>
                    }
                </div>

                @if (Model.Listings.TotalPages > 1)
                {
                    <nav class="pager">
                        @if (Model.Listings.HasPreviousPage)
                        {
                            <a asp-action="Index" asp-route-status="@status" asp-route-locked="@locked"
                               asp-route-search="@search" asp-route-page="@(Model.Listings.PageNumber - 1)">← @L["Prev"]</a>
                        }
                        else
                        {
                            <span class="disabled">← @L["Prev"]</span>
                        }
                        <span class="current">@L["{0} of {1}", Model.Listings.PageNumber, Model.Listings.TotalPages]</span>
                        @if (Model.Listings.HasNextPage)
                        {
                            <a asp-action="Index" asp-route-status="@status" asp-route-locked="@locked"
                               asp-route-search="@search" asp-route-page="@(Model.Listings.PageNumber + 1)">@L["Next"] →</a>
                        }
                        else
                        {
                            <span class="disabled">@L["Next"] →</span>
                        }
                    </nav>
                }
            </div>
        }
    </div>
</section>

@* One dialog, reused for whichever listing the agent asks about. The body is fetched on
   demand — rendering 76 sets of charts up front would cost far more than it's worth. *@
<dialog id="statsModal" class="stats-modal" aria-labelledby="statsModalTitle">
    <div class="stats-modal-head">
        <h2 id="statsModalTitle">@L["Listing stats"]</h2>
        <button type="button" class="stats-modal-close" data-stats-close aria-label="@L["Close"]">✕</button>
    </div>
    <div class="stats-modal-body" id="statsModalBody">
        <p class="stats-modal-status">@L["Loading…"]</p>
    </div>
</dialog>

@section Scripts {
    <script src="~/js/listing-stats.js" asp-append-version="true"></script>
}
