@using System.Globalization
@using RealEstatePortal.Domain.Enums
@model RealEstatePortal.Application.Agents.Queries.GetAgentDashboard.AgentDashboardDto
@{
    ViewData["Title"] = "Dashboard";
    var inv = CultureInfo.InvariantCulture;

    // Week-over-week delta. The arrow + wording carry the direction, never colour alone.
    (string Arrow, string Css, string Text) Delta(int current, int previous)
    {
        if (previous == 0)
            return current == 0 ? ("→", "flat", "no change") : ("▲", "up", "new this week");

        var pct = (current - previous) * 100.0 / previous;
        if (Math.Abs(pct) < 0.5) return ("→", "flat", "level");
        return pct > 0
            ? ("▲", "up", $"{pct.ToString("0.#", inv)}%")
            : ("▼", "down", $"{Math.Abs(pct).ToString("0.#", inv)}%");
    }

    var viewsDelta = Delta(Model.Views7d, Model.ViewsPrev7d);
    var inqDelta = Delta(Model.Inquiries7d, Model.InquiriesPrev7d);
}

<section class="dash-sec">
    <div class="container">
        <div class="dash-hero">
            <h1>Dashboard</h1>
            <p class="lead">How your listings are performing.</p>
        </div>

        @if (Model.TotalListings == 0)
        {
            <div class="empty-state">
                <span class="value">No listings yet</span>
                Once you publish a listing, its views and inquiries will show up here.
                <div style="margin-top:1rem;"><a class="btn btn-primary" asp-controller="Listings" asp-action="Create">Create a listing</a></div>
            </div>
        }
        else
        {
            <div class="kpi-row">
                <div class="kpi">
                    <div class="kpi-label">Total views</div>
                    <div class="kpi-value">@Model.TotalViews.ToString("N0")</div>
                </div>
                <div class="kpi">
                    <div class="kpi-label" title="Distinct visitors over the recent window. Older activity is aggregated and can't be de-duplicated.">Unique visitors · recent</div>
                    <div class="kpi-value">@Model.UniqueVisitors.ToString("N0")</div>
                </div>
                <div class="kpi">
                    <div class="kpi-label">Views · 7 days</div>
                    <div class="kpi-value">@Model.Views7d.ToString("N0")</div>
                    <div class="kpi-delta @viewsDelta.Css">
                        <span aria-hidden="true">@viewsDelta.Arrow</span> @viewsDelta.Text
                        <span class="kpi-delta-note">vs previous 7 days</span>
                    </div>
                </div>
                <div class="kpi">
                    <div class="kpi-label">Views · 30 days</div>
                    <div class="kpi-value">@Model.Views30d.ToString("N0")</div>
                </div>
                <div class="kpi">
                    <div class="kpi-label">Inquiries · 7 days</div>
                    <div class="kpi-value">
                        <a asp-controller="Inquiries" asp-action="Index" style="color:inherit;">@Model.Inquiries7d.ToString("N0")</a>
                    </div>
                    <div class="kpi-delta @inqDelta.Css">
                        <span aria-hidden="true">@inqDelta.Arrow</span> @inqDelta.Text
                        <span class="kpi-delta-note">vs previous 7 days · @Model.TotalInquiries.ToString("N0") all time</span>
                    </div>
                </div>
                <div class="kpi">
                    <div class="kpi-label" title="How many inquiries each 100 views produced over the last 30 days.">Inquiries / 100 views</div>
                    <div class="kpi-value">@Model.ConversionPer100.ToString("0.0", inv)</div>
                    <div class="kpi-delta flat"><span class="kpi-delta-note">last 30 days</span></div>
                </div>
                <div class="kpi">
                    <div class="kpi-label">Active listings</div>
                    <div class="kpi-value">@Model.ActiveListings / @Model.TotalListings</div>
                </div>
            </div>

            @* Two measures on very different scales get two charts — never one plot with two y-axes. *@
            <div class="chart-pair">
                @await Html.PartialAsync("_TrendChart",
                    (Model.ViewTrend, "Views", "views", "views", "view"))
                @await Html.PartialAsync("_TrendChart",
                    (Model.InquiryTrend, "Inquiries", "inquiries", "inquiries", "inquiry"))
            </div>

            <div class="dash-card">
                <div class="dash-card-head">
                    <h2>Portfolio</h2>
                    <span class="dash-card-sub">how your @Model.TotalListings listing@(Model.TotalListings == 1 ? "" : "s") break down</span>
                </div>
                <div class="breakdown-row">
                    @await Html.PartialAsync("_Breakdown", (Model.StatusBreakdown, "By status"))
                    @await Html.PartialAsync("_Breakdown", (Model.TypeBreakdown, "By listing type"))
                </div>
            </div>

            <div class="dash-card">
                <div class="dash-card-head">
                    <h2>By listing</h2>
                    <span class="dash-card-sub">ranked by total views</span>
                </div>
                <div class="table-scroll">
                    <table class="stats-table">
                        <thead>
                            <tr>
                                <th>Listing</th>
                                <th>Status</th>
                                <th class="num">7 days</th>
                                <th class="num">30 days</th>
                                <th class="num">Total views</th>
                                <th class="num">Unique</th>
                                <th class="num">Inquiries · 7 days</th>
                                <th class="num">Total inquiries</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.Listings)
                            {
                                <tr>
                                    <td>
                                        <a asp-controller="Listings" asp-action="Details" asp-route-id="@row.Id" asp-route-slug="@row.Slug">@row.Title</a>
                                    </td>
                                    <td><span class="status-pill status-@row.Status.ToString().ToLowerInvariant()">@row.Status</span></td>
                                    <td class="num">@row.Views7d.ToString("N0")</td>
                                    <td class="num">@row.Views30d.ToString("N0")</td>
                                    <td class="num">@row.TotalViews.ToString("N0")</td>
                                    <td class="num">@row.UniqueVisitors.ToString("N0")</td>
                                    <td class="num">@row.Inquiries7d.ToString("N0")</td>
                                    <td class="num">@row.Inquiries.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</section>
