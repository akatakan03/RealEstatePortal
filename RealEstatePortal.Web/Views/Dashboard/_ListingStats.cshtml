@using System.Globalization
@model RealEstatePortal.Application.Agents.Queries.GetListingStats.ListingStatsDto
@{
    var inv = CultureInfo.InvariantCulture;

    var viewsDelta = TrendDelta.Between(Model.Views7d, Model.ViewsPrev7d);
    var favDelta = TrendDelta.Between(Model.Favorites7d, Model.FavoritesPrev7d);
    var inqDelta = TrendDelta.Between(Model.Inquiries7d, Model.InquiriesPrev7d);

    var saves30 = Model.Favorites30dEquivalent;

    string Ago(DateTimeOffset? when) =>
        when is null ? L["never"].Value : when.Value.Medium();
}

<div class="ls-head">
    <div>
        <h2 id="listingStatsTitle">@Model.Title</h2>
        <div class="ls-meta">
            @if (Model.IsLocked)
            {
                <span class="status-pill status-locked">🔒 @L["Locked"]</span>
            }
            else
            {
                <span class="status-pill status-@Model.Status.ToString().ToLowerInvariant()">@L.Localize(Model.Status)</span>
            }
            <span>@Model.PriceAmount.ToString("N0") @Model.PriceCurrency</span>
            <span>@L["Listed {0} days ago", Model.DaysListed]</span>
        </div>
    </div>
    <a class="btn btn-ghost btn-sm" href="@Url.ListingUrl(Model.Id, Model.Slug)"
       target="_blank" rel="noopener">@L["Open listing"] ↗</a>
</div>

@* The funnel is the story: of everyone who looked, how many cared enough to save, and how
   many actually made contact. Counts alone can't answer that — the rates can. *@
<div class="ls-funnel">
    <div class="fn-step">
        <span class="fn-value">@Model.Views30d.ToString("N0")</span>
        <span class="fn-label">@L["views · last 30 days"]</span>
        <span class="fn-rate">@L["{0} per day", Model.ViewsPerDay.ToString("0.#")]</span>
    </div>
    <span class="fn-arrow" aria-hidden="true">→</span>
    <div class="fn-step">
        <span class="fn-value">@saves30.ToString("N0")</span>
        <span class="fn-label">@L["saved it"]</span>
        <span class="fn-rate">@L["{0} per 100 views", Model.SavesPer100Views.ToString("0.0")]</span>
    </div>
    <span class="fn-arrow" aria-hidden="true">→</span>
    <div class="fn-step">
        <span class="fn-value">@Model.Inquiries30d.ToString("N0")</span>
        <span class="fn-label">@L["got in touch"]</span>
        <span class="fn-rate">@L["{0} per 100 views", Model.InquiriesPer100Views.ToString("0.0")]</span>
    </div>
</div>

<div class="kpi-row ls-kpis">
    <div class="kpi">
        <div class="kpi-label">@L["Views · 7 days"]</div>
        <div class="kpi-value">@Model.Views7d.ToString("N0")</div>
        <div class="kpi-delta @viewsDelta.Css">
            <span aria-hidden="true">@viewsDelta.Arrow</span> @L[viewsDelta.Text]
            <span class="kpi-delta-note">@L["vs previous 7 days"]</span>
        </div>
    </div>
    <div class="kpi">
        <div class="kpi-label">@L["Saves · 7 days"]</div>
        <div class="kpi-value">@Model.Favorites7d.ToString("N0")</div>
        <div class="kpi-delta @favDelta.Css">
            <span aria-hidden="true">@favDelta.Arrow</span> @L[favDelta.Text]
            <span class="kpi-delta-note">@L["{0} all time", Model.TotalFavorites.ToString("N0")]</span>
        </div>
    </div>
    <div class="kpi">
        <div class="kpi-label">@L["Inquiries · 7 days"]</div>
        <div class="kpi-value">@Model.Inquiries7d.ToString("N0")</div>
        <div class="kpi-delta @inqDelta.Css">
            <span aria-hidden="true">@inqDelta.Arrow</span> @L[inqDelta.Text]
            <span class="kpi-delta-note">@L["{0} all time", Model.TotalInquiries.ToString("N0")]</span>
        </div>
    </div>
    <div class="kpi">
        <div class="kpi-label" title="@L["All-time views, including the older activity that has been rolled up into daily totals."]">@L["Total views"]</div>
        <div class="kpi-value">@Model.TotalViews.ToString("N0")</div>
        <div class="kpi-delta flat"><span class="kpi-delta-note">@L["{0} unique · recent", Model.UniqueVisitors.ToString("N0")]</span></div>
    </div>
</div>

@* A raw count means nothing on its own — the agent's own average is the only honest yardstick. *@
@if (Model.PortfolioListingCount > 1 && Model.PortfolioAvgViews30d > 0)
{
    var ratio = Model.VsPortfolio;
    var pct = Math.Abs(ratio - 1) * 100;
    var verdict = Math.Abs(ratio - 1) < 0.05
        ? L["about average for your portfolio"].Value
        : ratio > 1
            ? L["{0}% above your portfolio average", pct.ToString("0")].Value
            : L["{0}% below your portfolio average", pct.ToString("0")].Value;

    @* One sentence, one entry — the verdict goes in as a placeholder so a translator can put
       it where the grammar wants it, and keeps its emphasis on the way in. *@
    <p class="ls-benchmark">
        @Html.Raw(L["Over the last 30 days this listing is {0} ({1} views on average across your {2} listings).",
                   $"<strong>{verdict}</strong>",
                   Model.PortfolioAvgViews30d.ToString("0.#"),
                   Model.PortfolioListingCount])
    </p>
}

<div class="chart-pair">
    @await Html.PartialAsync("_TrendChart", (Model.ViewTrend, "Daily views", "views", "views", "view"))
    @await Html.PartialAsync("_TrendChart", (Model.FavoriteTrend, "Daily saves", "saves", "saves", "save"))
</div>

<div class="chart-pair ls-charts-lower">
    @await Html.PartialAsync("_TrendChart", (Model.InquiryTrend, "Daily inquiries", "inquiries", "inquiries", "inquiry"))

    <div class="dash-card">
        <div class="dash-card-head">
            <h2>@L["Activity"]</h2>
            <span class="dash-card-sub">@L["the last time anything happened"]</span>
        </div>
        <dl class="ls-facts">
            <div><dt>@L["Last view"]</dt><dd>@Ago(Model.LastViewAt)</dd></div>
            <div><dt>@L["Last inquiry"]</dt><dd>@Ago(Model.LastInquiryAt)</dd></div>
            <div><dt>@L["Published"]</dt><dd>@Model.CreatedAt.Medium()</dd></div>
            <div><dt>@L["Price changes"]</dt><dd>@Math.Max(Model.PriceHistory.Count - 1, 0)</dd></div>
        </dl>
    </div>
</div>

@* Only drawn once the price has actually moved — a single point is not a history. *@
@await Html.PartialAsync("~/Views/Listings/_PriceHistory.cshtml", Model.PriceHistory)
