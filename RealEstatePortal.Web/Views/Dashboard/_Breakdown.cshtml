@using System.Globalization
@using RealEstatePortal.Application.Agents.Queries.GetAgentDashboard
@model (IReadOnlyList<BreakdownItemDto> Items, string Title)
@{
    var inv = CultureInfo.InvariantCulture;
    // Three validated series colours plus a neutral fourth. A single leftover category keeps
    // its own label in that neutral slot — folding one item into "Other" would drop a real
    // name for nothing. Two or more leftovers fold, since there is no fifth colour.
    var items = Model.Items.Count <= 4
        ? Model.Items.ToList()
        : Model.Items.Take(3)
            .Append(new BreakdownItemDto("Other", Model.Items.Skip(3).Sum(i => i.Count)))
            .ToList();
    var total = Math.Max(items.Sum(i => i.Count), 1);
}

<div class="breakdown">
    <h3 class="breakdown-title">@Model.Title</h3>
    <div class="stack" role="img" aria-label="@Model.Title breakdown">
        @for (var i = 0; i < items.Count; i++)
        {
            var share = items[i].Count * 100.0 / total;
            <div class="stack-seg seg-@(i + 1)" style="width:@share.ToString("0.##", inv)%"
                 title="@items[i].Label: @items[i].Count (@share.ToString("0.#", inv)%)"></div>
        }
    </div>
    @* Legend carries identity and the values — never colour alone, never a clipped inline label. *@
    <ul class="stack-legend">
        @for (var i = 0; i < items.Count; i++)
        {
            <li>
                <span class="swatch seg-@(i + 1)" aria-hidden="true"></span>
                <span class="lg-label">@items[i].Label</span>
                <span class="lg-value">@items[i].Count.ToString("N0")</span>
            </li>
        }
    </ul>
</div>
