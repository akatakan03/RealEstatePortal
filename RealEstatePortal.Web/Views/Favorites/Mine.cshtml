@using RealEstatePortal.Domain.Enums
@model List<RealEstatePortal.Application.Listings.Queries.GetListings.ListingBriefDto>
@{
    ViewData["Title"] = L["Saved listings"].Value;
}

<div class="dash">
    <div class="container">
        <div class="dash-head">
            <div>
                <span class="eyebrow">@L["Your account"]</span>
                <h1 class="page-title">@L["Saved listings"]</h1>
            </div>
        </div>

        @if (!Model.Any())
        {
            <div class="form-card card-empty">
                @L["You haven't saved any listings yet."] <a asp-controller="Listings" asp-action="Index" style="color:var(--brass-dk);font-weight:600;">@L["Browse listings"]</a>.
            </div>
        }
        else
        {
            <div class="card-grid">
                @foreach (var listing in Model)
                {
                    <div class="listing-card">
                        <a class="lc-link" href="@Url.ListingUrl(listing.Id, listing.Slug)" style="color:inherit;">
                            <div class="lc-media">
                                <span class="lc-tag @(listing.ListingType == ListingType.Rent ? "rent" : "")">@L.Localize(listing.ListingType)</span>
                                @{ var cover = ListingImages.CoverOrPlaceholder(listing.CoverThumbnailUrl, listing.Id, Configuration.GetValue<bool>("Demo:PlaceholderImages")); }
                                @if (!string.IsNullOrEmpty(cover))
                                {
                                    <img src="@cover" alt="@listing.Title" loading="lazy" />
                                }
                                else
                                {
                                    <div class="noimg">@L["No photo yet"]</div>
                                }
                            </div>
                        </a>
                        <div class="lc-body">
                            <div class="lc-loc">@L.Localize(listing.PropertyType)</div>
                            <div class="lc-title">@listing.Title</div>
                            <div class="lc-price"><span class="value">@listing.PriceAmount.ToString("N0") @listing.PriceCurrency</span></div>
                            <form asp-controller="Favorites" asp-action="Toggle" method="post" style="margin-top:.9rem;">
                                <input type="hidden" name="listingId" value="@listing.Id" />
                                <input type="hidden" name="returnUrl" value="/Favorites/Mine" />
                                <button type="submit" class="btn btn-ghost btn-sm" style="width:100%;">♥ @L["Remove"]</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>