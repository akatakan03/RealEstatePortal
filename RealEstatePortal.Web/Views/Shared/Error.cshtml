@model ErrorViewModel
@{
    ViewData["Title"] = L["Something went wrong"].Value;
}

@* This is the page a visitor sees when something fails in production. The scaffolded version
   explained how to switch ASPNETCORE_ENVIRONMENT to Development, which is instructions for the
   developer printed on a public page — it is gone. What is left is what a visitor can act on:
   what happened, a way back, and the request id to quote if they get in touch. *@
<div class="form-page">
    <div class="container">
        <div class="form-shell narrow">
            <h1 class="page-title">@L["Something went wrong"]</h1>
            <div class="form-card">
                <p>@L["We couldn't complete that request. Nothing you had saved has been lost — please try again in a moment."]</p>

                @if (Model.ShowRequestId)
                {
                    <p class="muted">
                        @L["If it keeps happening, quote this reference:"] <code>@Model.RequestId</code>
                    </p>
                }

                <div class="form-actions bare">
                    <a asp-controller="Listings" asp-action="Index" class="btn btn-primary">@L["Browse listings"]</a>
                </div>
            </div>
        </div>
    </div>
</div>
