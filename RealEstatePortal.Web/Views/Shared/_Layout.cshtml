<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EmlakPortal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Spectral:wght@400;500;600&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body>
    <header class="site-header">
        <div class="container site-nav">
            <a class="brand" asp-controller="Home" asp-action="Index">
                <span class="mark"></span>Emlak<span class="accent">Portal</span>
            </a>

            <ul class="nav-links">
                <li><a asp-controller="Listings" asp-action="Index">Browse</a></li>
                @if (User.IsInRole("Agent"))
                {
                    <li>
                        <a class="nav-cta" asp-controller="Listings" asp-action="Create">
                            <span class="nav-cta-plus" aria-hidden="true">+</span> New listing
                        </a>
                    </li>
                }
            </ul>

            <div class="nav-actions">
                @if (User.Identity is not null && User.Identity.IsAuthenticated)
                {
                    var displayName = User.Identity.Name ?? "Account";
                    var initial = string.IsNullOrWhiteSpace(displayName) ? "?" : displayName.Trim()[..1].ToUpperInvariant();
                    <div class="user-menu" data-user-menu>
                        <button type="button" class="user-trigger" data-user-menu-trigger aria-haspopup="true" aria-expanded="false">
                            <span class="user-avatar" aria-hidden="true">@initial</span>
                            <span class="user-name">@displayName</span>
                            <span class="user-caret" aria-hidden="true">▾</span>
                        </button>
                        <div class="user-dropdown" data-user-menu-panel role="menu">
                            <div class="menu-section">
                                <span class="menu-label">Account</span>
                                <a role="menuitem" asp-controller="Favorites" asp-action="Mine">Saved</a>
                                <a role="menuitem" asp-controller="SavedSearches" asp-action="Mine">Alerts</a>
                                <a role="menuitem" asp-controller="Profile" asp-action="Index">Profile</a>
                            </div>
                            @if (User.IsInRole("Agent"))
                            {
                                <div class="menu-divider"></div>
                                <div class="menu-section">
                                    <span class="menu-label">Workspace</span>
                                    <a role="menuitem" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                                    <a role="menuitem" asp-controller="Listings" asp-action="Mine">My listings</a>
                                    <a role="menuitem" asp-controller="Inquiries" asp-action="Index" class="menu-item-badge">
                                        <span>Inquiries</span> @await Component.InvokeAsync("UnreadInquiries")
                                    </a>
                                </div>
                            }
                            @if (User.IsInRole("Admin"))
                            {
                                <div class="menu-divider"></div>
                                <div class="menu-section">
                                    <span class="menu-label">Admin</span>
                                    <a role="menuitem" asp-controller="Admin" asp-action="Listings">Manage listings</a>
                                </div>
                            }
                            <div class="menu-divider"></div>
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="menu-signout" role="menuitem">Sign out</button>
                            </form>
                        </div>
                    </div>
                }
                else
                {
                    <a class="btn btn-ghost btn-sm" asp-controller="Account" asp-action="Login">Sign in</a>
                    <a class="btn btn-ink btn-sm" asp-controller="Account" asp-action="Register">Sign up</a>
                }
            </div>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="foot-grid">
                <div class="foot-brand">
                    <a class="brand" asp-controller="Home" asp-action="Index"><span class="mark"></span>Emlak<span class="accent">Portal</span></a>
                    <p>A calmer way to find property in İstanbul — verified listings, local agents, and the details that matter.</p>
                </div>
                <div class="foot-col">
                    <h4>Explore</h4>
                    <a asp-controller="Listings" asp-action="Index">Browse listings</a>
                    <a asp-controller="Account" asp-action="Register">List a property</a>
                </div>
                <div class="foot-col">
                    <h4>Account</h4>
                    <a asp-controller="Account" asp-action="Login">Sign in</a>
                    <a asp-controller="Account" asp-action="Register">Register</a>
                </div>
                <div class="foot-col">
                    <h4>Developer</h4>
                    <a href="/swagger">API docs</a>
                    <a href="/sitemap.xml">Sitemap</a>
                </div>
            </div>
            <div class="foot-bottom">
                <span>© @DateTime.Now.Year EmlakPortal</span>
                <span>Made in İstanbul</span>
            </div>
        </div>
    </footer>

    @if (User.IsInRole("Agent"))
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
        <script src="~/js/notifications.js" asp-append-version="true"></script>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/user-menu.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>