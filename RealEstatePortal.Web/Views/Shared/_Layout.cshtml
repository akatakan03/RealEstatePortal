<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EmlakPortal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Spectral:wght@400;500;600&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body>
    <header class="site-header">
        <div class="container site-nav">
            <a class="brand" asp-controller="Home" asp-action="Index">
                <span class="mark"></span>Emlak<span class="accent">Portal</span>
            </a>

            <ul class="nav-links">
                <li><a asp-controller="Listings" asp-action="Index">Browse</a></li>
                @if (User.Identity is not null && User.Identity.IsAuthenticated)
                {
                    <li><a asp-controller="Favorites" asp-action="Mine">Saved</a></li>
                }
                @if (User.IsInRole("Agent"))
                {
                    <li><a asp-controller="Listings" asp-action="Mine">My listings</a></li>
                    <li>
                        <a asp-controller="Inquiries" asp-action="Index">
                            Inquiries @await Component.InvokeAsync("UnreadInquiries")
                        </a>
                    </li>
                }
                @if (User.IsInRole("Admin"))
                {
                    <li><a asp-controller="Admin" asp-action="Listings">Admin</a></li>
                }
            </ul>

            <div class="nav-actions">
                @if (User.Identity is not null && User.Identity.IsAuthenticated)
                {
                    <span style="font-size:.9rem;color:var(--muted);">@User.Identity.Name</span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="btn btn-ghost btn-sm">Sign out</button>
                    </form>
                }
                else
                {
                    <a class="btn btn-ghost btn-sm" asp-controller="Account" asp-action="Login">Sign in</a>
                    <a class="btn btn-ink btn-sm" asp-controller="Account" asp-action="Register">Sign up</a>
                }
            </div>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="foot-grid">
                <div class="foot-brand">
                    <a class="brand" asp-controller="Home" asp-action="Index"><span class="mark"></span>Emlak<span class="accent">Portal</span></a>
                    <p>A calmer way to find property in İstanbul — verified listings, local agents, and the details that matter.</p>
                </div>
                <div class="foot-col">
                    <h4>Explore</h4>
                    <a asp-controller="Listings" asp-action="Index">Browse listings</a>
                    <a asp-controller="Account" asp-action="Register">List a property</a>
                </div>
                <div class="foot-col">
                    <h4>Account</h4>
                    <a asp-controller="Account" asp-action="Login">Sign in</a>
                    <a asp-controller="Account" asp-action="Register">Register</a>
                </div>
                <div class="foot-col">
                    <h4>Developer</h4>
                    <a href="/swagger">API docs</a>
                    <a href="/sitemap.xml">Sitemap</a>
                </div>
            </div>
            <div class="foot-bottom">
                <span>© @DateTime.Now.Year EmlakPortal</span>
                <span>Made in İstanbul</span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>