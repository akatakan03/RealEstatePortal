@using RealEstatePortal.Domain.Enums
@model List<RealEstatePortal.Application.SavedSearches.Queries.GetMySavedSearches.SavedSearchDto>
@{
    ViewData["Title"] = "Saved searches";
}

<div class="dash">
    <div class="container">
        <div class="dash-head">
            <div>
                <span class="eyebrow">Your account</span>
                <h1 class="page-title">Saved searches</h1>
            </div>
            <a class="btn btn-ghost" asp-controller="Favorites" asp-action="Mine">♥ Saved listings</a>
        </div>

        <div class="form-card" style="margin-bottom:1.5rem;color:var(--muted);">
            We'll email you when a newly published listing matches one of these searches.
        </div>

        @if (!Model.Any())
        {
            <div class="form-card" style="text-align:center;color:var(--muted);">
                No saved searches yet. Set some filters on the <a asp-controller="Listings" asp-action="Index" style="color:var(--brass-dk);font-weight:600;">browse page</a> and click "Save this search".
            </div>
        }
        else
        {
            <div class="table-card">
                <table class="table">
                    <thead>
                        <tr><th>Name</th><th>Criteria</th><th></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model)
                        {
                            <tr>
                                <td class="row-title">@s.Name</td>
                                <td style="color:var(--muted);">
                                    @{
                                        var parts = new List<string>();
                                        if (!string.IsNullOrWhiteSpace(s.Keyword)) parts.Add($"“{s.Keyword}”");
                                        if (s.ListingType.HasValue) parts.Add(s.ListingType.ToString()!);
                                        if (s.PropertyType.HasValue) parts.Add(s.PropertyType.ToString()!);
                                        if (s.MinBedrooms.HasValue) parts.Add($"{s.MinBedrooms}+ bed");
                                        if (s.MaxPrice.HasValue) parts.Add($"≤ {s.MaxPrice.Value:N0}");
                                    }
                                    @(parts.Any() ? string.Join(" · ", parts) : "Any listing")
                                </td>
                                <td>
                                    <form asp-action="Delete" method="post" class="row-actions" onsubmit="return confirm('Delete this saved search?');">
                                        <input type="hidden" name="id" value="@s.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>