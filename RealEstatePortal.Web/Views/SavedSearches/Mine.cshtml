@using RealEstatePortal.Domain.Enums
@model List<RealEstatePortal.Application.SavedSearches.Queries.GetMySavedSearches.SavedSearchDto>
@{
    ViewData["Title"] = L["Saved searches"].Value;
}

<div class="dash">
    <div class="container">
        <div class="dash-head">
            <div>
                <span class="eyebrow">@L["Your account"]</span>
                <h1 class="page-title">@L["Saved searches"]</h1>
            </div>
            <a class="btn btn-ghost" asp-controller="Favorites" asp-action="Mine">♥ @L["Saved listings"]</a>
        </div>

        <div class="form-card" style="margin-bottom:1.5rem;color:var(--muted);">
            @L["We'll email you when a newly published listing matches one of these searches."]
        </div>

        @if (!Model.Any())
        {
            <div class="form-card card-empty">
                @Html.Raw(L["No saved searches yet. Set some filters on the {0} and save the search you want to be told about.",
                    $"<a href=\"{Url.Action("Index", "Listings")}\" style=\"color:var(--brass-dk);font-weight:600;\">{L["browse page"].Value}</a>"])
            </div>
        }
        else
        {
            <div class="table-card">
                <table class="table">
                    <thead>
                        @* Not the "Name" key — that one labels the contact form's full-name field
                           and reads "Ad soyad". This column is the name given to the search. *@
                        <tr><th>@L["Search name"]</th><th>@L["Criteria"]</th><th></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model)
                        {
                            <tr>
                                <td class="row-title">@s.Name</td>
                                <td class="muted">
                                    @{
                                        var parts = new List<string>();
                                        if (!string.IsNullOrWhiteSpace(s.Keyword)) parts.Add($"“{s.Keyword}”");
                                        if (s.ListingType.HasValue) parts.Add(L.Localize(s.ListingType.Value));
                                        if (s.PropertyType.HasValue) parts.Add(L.Localize(s.PropertyType.Value));
                                        if (s.MinBedrooms.HasValue) parts.Add(L["{0}+ bedrooms", s.MinBedrooms].Value);
                                        if (s.MaxPrice.HasValue) parts.Add($"≤ {s.MaxPrice.Value:N0}");
                                    }
                                    @(parts.Any() ? string.Join(" · ", parts) : L["Any listing"].Value)
                                </td>
                                <td>
                                    @* The message lands inside a JS string literal, so it must not
                                       contain an apostrophe: Razor encodes it to &#x27; and the
                                       browser decodes it back, breaking out of the quotes. Turkish
                                       phrasing here is deliberately apostrophe-free. *@
                                    <form asp-action="Delete" method="post" class="row-actions" onsubmit="return confirm('@L["Delete this saved search?"]');">
                                        <input type="hidden" name="id" value="@s.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm">@L["Delete"]</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
