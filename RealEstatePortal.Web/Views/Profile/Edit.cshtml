@model RealEstatePortal.Web.Models.Profile.EditProfileViewModel
@{
    ViewData["Title"] = "Edit profile";
}

<div class="form-page">
    <div class="container">
        <div class="form-shell">
            <span class="eyebrow">Your account</span>
            <h1 class="page-title" style="margin-bottom:1.5rem;">Edit profile</h1>

            @if (TempData["ProfileError"] is string err)
            {
                <div class="alert alert-danger" style="margin-bottom:1.5rem;">@err</div>
            }

            <div class="form-card" style="margin-bottom:1.5rem;">
                <h3 class="profile-h3">Profile photo</h3>
                <form asp-action="Avatar" method="post" enctype="multipart/form-data">
                    <input type="file" name="avatar" accept="image/*" class="form-control" required />
                    <p class="form-hint">Square images look best — it's resized and optimised automatically.</p>
                    <button type="submit" class="btn btn-ghost btn-sm" style="margin-top:.6rem;">Upload photo</button>
                </form>
            </div>

            <div class="form-card">
                <h3 class="profile-h3">Your details</h3>
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:1rem;"></div>

                    <div class="mb-field">
                        <label asp-for="DisplayName" class="form-label"></label>
                        <input asp-for="DisplayName" class="form-control" />
                        <span asp-validation-for="DisplayName" class="text-danger"></span>
                    </div>
                    <div class="mb-field">
                        <label asp-for="Phone" class="form-label"></label>
                        <input asp-for="Phone" class="form-control" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>
                    <div class="mb-field">
                        <label asp-for="Bio" class="form-label"></label>
                        <textarea asp-for="Bio" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Bio" class="text-danger"></span>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Save changes</button>
                        <a asp-action="Index" class="btn btn-ghost">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}