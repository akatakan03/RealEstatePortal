@model RealEstatePortal.Web.Models.Profile.EditProfileViewModel
@{
    ViewData["Title"] = L["Edit profile"].Value;
}

<div class="form-page">
    <div class="container">
        <div class="form-shell">
            <span class="eyebrow">@L["Your account"]</span>
            <h1 class="page-title" style="margin-bottom:1.5rem;">@L["Edit profile"]</h1>

            @* Translated here, not in the controller: see the note in Index.cshtml. *@
            @if (TempData["ProfileError"] is string err)
            {
                <div class="alert alert-danger">@L[err]</div>
            }

            <div class="form-card" style="margin-bottom:1.5rem;">
                <h3 class="profile-h3">@L["Profile photo"]</h3>
                <form asp-action="Avatar" method="post" enctype="multipart/form-data">
                    <input type="file" name="avatar" accept="image/*" class="form-control" required />
                    <p class="form-hint">@L["Square images look best — it's resized and optimised automatically."]</p>
                    <button type="submit" class="btn btn-ghost btn-sm" style="margin-top:.6rem;">@L["Upload photo"]</button>
                </form>
            </div>

            <div class="form-card">
                <h3 class="profile-h3">@L["Your details"]</h3>
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:1rem;"></div>

                    <div class="mb-field">
                        <label asp-for="DisplayName" class="form-label"></label>
                        <input asp-for="DisplayName" class="form-control" />
                        <span asp-validation-for="DisplayName" class="text-danger"></span>
                    </div>
                    <div class="mb-field">
                        <label asp-for="Phone" class="form-label"></label>
                        <input asp-for="Phone" class="form-control" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>
                    <div class="mb-field">
                        <label asp-for="Bio" class="form-label"></label>
                        <textarea asp-for="Bio" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Bio" class="text-danger"></span>
                    </div>

                    <div class="mb-field">
                        <label asp-for="PreferredCulture" class="form-label"></label>
                        @* Each language names itself, never translated — the same rule the header
                           switcher follows. *@
                        <select asp-for="PreferredCulture" class="form-select">
                            @foreach (var code in SupportedCultures.Codes)
                            {
                                <option value="@code">@SupportedCultures.NameOf(code)</option>
                            }
                        </select>
                        <p class="form-hint">@L["The language we write to you in, and the one the site opens in."]</p>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">@L["Save changes"]</button>
                        <a asp-action="Index" class="btn btn-ghost">@L["Cancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}