@using RealEstatePortal.Domain.Enums
@model List<RealEstatePortal.Application.Admin.Queries.GetListingsForModeration.AdminListingDto>
@{
    ViewData["Title"] = "Moderation";
    var current = ViewBag.StatusFilter as ListingStatus?;
}

<div class="dash">
    <div class="container">
        <div class="dash-head">
            <div>
                <span class="eyebrow">Admin</span>
                <h1 class="page-title">Listing moderation</h1>
            </div>
            <form asp-action="Listings" method="get" style="display:flex;align-items:center;gap:.6rem;">
                <label style="font-weight:600;font-size:.9rem;">Status</label>
                <select name="status" class="form-select select-inline" onchange="this.form.submit()">
                    <option value="">All</option>
                    @foreach (var s in Enum.GetValues<ListingStatus>())
                    {
                        <option value="@s" selected="@(current == s)">@s</option>
                    }
                </select>
            </form>
        </div>

        @if (!Model.Any())
        {
            <div class="form-card" style="text-align:center;color:var(--muted);">No listings@(current is null ? "" : $" with status {current}").</div>
        }
        else
        {
            <div class="table-card">
                <table class="table">
                    <thead>
                        <tr><th>Title</th><th>Owner</th><th>Status</th><th>Price</th><th></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var l in Model)
                        {
                            <tr>
                                <td class="row-title"><a asp-controller="Listings" asp-action="Details" asp-route-id="@l.Id">@l.Title</a></td>
                                <td style="color:var(--muted);">@(l.OwnerEmail ?? "—")</td>
                                <td><span class="badge-status badge-@l.Status.ToString().ToLower()">@l.Status</span></td>
                                <td><span class="value">@l.PriceAmount.ToString("N0") @l.PriceCurrency</span></td>
                                <td>
                                    <div class="row-actions">
                                        @if (l.Status != ListingStatus.Archived)
                                        {
                                            <form asp-action="Archive" method="post">
                                                <input type="hidden" name="id" value="@l.Id" />
                                                <input type="hidden" name="status" value="@current" />
                                                <button type="submit" class="btn btn-ghost btn-sm">Archive</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="Restore" method="post">
                                                <input type="hidden" name="id" value="@l.Id" />
                                                <input type="hidden" name="status" value="@current" />
                                                <button type="submit" class="btn btn-ghost btn-sm">Restore</button>
                                            </form>
                                        }

                                        @if (l.IsLocked)
                                        {
                                            <form asp-action="Unlock" method="post">
                                                <input type="hidden" name="id" value="@l.Id" />
                                                <input type="hidden" name="status" value="@current" />
                                                <button type="submit" class="btn btn-ghost btn-sm">🔓 Unlock</button>
                                            </form>
                                        }

                                        <form asp-action="Delete" method="post" onsubmit="return confirm('Permanently delete this listing and its photos?');">
                                            <input type="hidden" name="id" value="@l.Id" />
                                            <input type="hidden" name="status" value="@current" />
                                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                        </form>
                                    </div>

                                    @if (!l.IsLocked)
                                    {
                                        <button type="button" class="btn btn-ghost btn-sm lock-trigger"
                                                data-id="@l.Id" data-title="@l.Title">
                                            🔒 Lock
                                        </button>
                                    }
                                    else
                                    {
                                        <div class="lock-note">🔒 Locked — @l.LockReason</div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<dialog id="lockDialog" class="lock-dialog">
    <form asp-action="Lock" method="post">
        <input type="hidden" name="id" id="lockId" />
        <input type="hidden" name="status" value="@current" />
        <h3 class="lock-dialog-title">Lock listing</h3>
        <p class="lock-dialog-sub" id="lockSubtitle">This takes the listing off the public site and prevents the agent from publishing it until you unlock it.</p>
        <label class="form-label" for="lockReason">Reason (the agent will see this and be emailed it)</label>
        <textarea name="reason" id="lockReason" class="form-control" rows="4" maxlength="500" required
                  placeholder="e.g. The photos don't match the described property. Please re-upload accurate images."></textarea>
        <div class="lock-dialog-actions">
            <button type="button" class="btn btn-ghost" id="lockCancel">Cancel</button>
            <button type="submit" class="btn btn-primary">Lock listing</button>
        </div>
    </form>
</dialog>

@section Scripts {
    <script>
        (function () {
            var dialog = document.getElementById('lockDialog');
            document.querySelectorAll('.lock-trigger').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    document.getElementById('lockId').value = btn.getAttribute('data-id');
                    document.getElementById('lockSubtitle').textContent =
                        'Locking “' + btn.getAttribute('data-title') + '”. This takes it off the public site until you unlock it.';
                    document.getElementById('lockReason').value = '';
                    dialog.showModal();
                });
            });
            document.getElementById('lockCancel').addEventListener('click', function () { dialog.close(); });
        })();
    </script>
}